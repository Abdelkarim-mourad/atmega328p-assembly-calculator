                                 .equ	PAGESIZE	= 64
                                 .equ	FIRSTBOOTSTART	= 0x3f00
                                 .equ	SECONDBOOTSTART	= 0x3e00
                                 .equ	THIRDBOOTSTART	= 0x3c00
                                 .equ	FOURTHBOOTSTART	= 0x3800
                                 .equ	SMALLBOOTSTART	= FIRSTBOOTSTART
                                 .equ	LARGEBOOTSTART	= FOURTHBOOTSTART
                                 
                                 
                                 
                                 ; ***** INTERRUPT VECTORS ************************************************
                                 .equ	INT0addr	= 0x0002	; External Interrupt Request 0
                                 .equ	INT1addr	= 0x0004	; External Interrupt Request 1
                                 .equ	PCI0addr	= 0x0006	; Pin Change Interrupt Request 0
                                 .equ	PCI1addr	= 0x0008	; Pin Change Interrupt Request 0
                                 .equ	PCI2addr	= 0x000a	; Pin Change Interrupt Request 1
                                 .equ	WDTaddr	= 0x000c	; Watchdog Time-out Interrupt
                                 .equ	OC2Aaddr	= 0x000e	; Timer/Counter2 Compare Match A
                                 .equ	OC2Baddr	= 0x0010	; Timer/Counter2 Compare Match A
                                 .equ	OVF2addr	= 0x0012	; Timer/Counter2 Overflow
                                 .equ	ICP1addr	= 0x0014	; Timer/Counter1 Capture Event
                                 .equ	OC1Aaddr	= 0x0016	; Timer/Counter1 Compare Match A
                                 .equ	OC1Baddr	= 0x0018	; Timer/Counter1 Compare Match B
                                 .equ	OVF1addr	= 0x001a	; Timer/Counter1 Overflow
                                 .equ	OC0Aaddr	= 0x001c	; TimerCounter0 Compare Match A
                                 .equ	OC0Baddr	= 0x001e	; TimerCounter0 Compare Match B
                                 .equ	OVF0addr	= 0x0020	; Timer/Couner0 Overflow
                                 .equ	SPIaddr	= 0x0022	; SPI Serial Transfer Complete
                                 .equ	URXCaddr	= 0x0024	; USART Rx Complete
                                 .equ	UDREaddr	= 0x0026	; USART, Data Register Empty
                                 .equ	UTXCaddr	= 0x0028	; USART Tx Complete
                                 .equ	ADCCaddr	= 0x002a	; ADC Conversion Complete
                                 .equ	ERDYaddr	= 0x002c	; EEPROM Ready
                                 .equ	ACIaddr	= 0x002e	; Analog Comparator
                                 .equ	TWIaddr	= 0x0030	; Two-wire Serial Interface
                                 .equ	SPMRaddr	= 0x0032	; Store Program Memory Read
                                 
                                 .equ	INT_VECTORS_SIZE	= 52	; size in words
                                 
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 ; ATmega328P – 2-digit + / - calculator
                                 ; LCD 8-bit on PORTB, keypad on PORTD
                                 ; Software delays only
                                 ;===========================================
                                 
                                 .include "m328pdef.inc"
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega328P.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m328Pdef.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega328P
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega328P
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M328PDEF_INC_
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 ;-------------------------------------------
                                 ; Data section: store operands/state in SRAM
                                 ;-------------------------------------------
                                 .dseg
000100                           OP1:    .byte 1      ; first operand  (0..99)
000101                           OP2:    .byte 1      ; second operand (0..99)
000102                           STATE:  .byte 1      ; 0=enter OP1, 1=enter OP2, 2=result
000103                           OPER:   .byte 1      ; '+' or '-'
                                 
                                 ;-------------------------------------------
                                 ; Code section
                                 ;-------------------------------------------
                                 .cseg
                                 .org 0x0000
000000 940c 0002                     jmp RESET        ; use absolute jump (no range issue)
                                 
                                 ; general-purpose registers
                                 .def Rtmp0 = r16
                                 .def Rtmp1 = r17
                                 .def Rtmp2 = r18
                                 .def Rtmp3 = r19
                                 .def Rval  = r20     ; used for value/result
                                 .def Rdel0 = r21
                                 .def Rdel1 = r22
                                 
                                 ;-------------------------------------------
                                 ; RESET
                                 ;-------------------------------------------
                                 RESET:
                                     ; init stack
000002 e008                          ldi Rtmp0, HIGH(RAMEND)
000003 bf0e                          out SPH, Rtmp0
000004 ef0f                          ldi Rtmp0, LOW(RAMEND)
000005 bf0d                          out SPL, Rtmp0
                                 
000006 d0c9                          rcall Init_Ports
000007 d159                          rcall Delay_ms20
000008 d0d5                          rcall Init_LCD
                                 
000009 d098                          rcall ClearLCD
00000a d08d                          rcall ResetCalc
                                 
                                 MainLoop:
00000b d0e8                          rcall GetKeyBlocking          ; ASCII key returned in Rtmp0
                                 
                                     ; ----- CLEAR (C) -----
00000c 3403                          cpi Rtmp0, 'C'
00000d f081                          breq Handle_Clear
                                 
                                     ; ----- PLUS -----
00000e 320b                          cpi Rtmp0, '+'
00000f f091                          breq Handle_Plus
                                 
                                     ; ----- MINUS -----
000010 320d                          cpi Rtmp0, '-'
000011 f119                          breq Handle_Minus
                                 
                                     ; ----- EQUAL (=) -----
000012 330d                          cpi Rtmp0, '='
000013 f039                          breq Equal_Near              ; short branch ? allowed
                                                                  ; then jump to real handler
                                 
                                     ; ---------- DIGIT 0..9 ? ----------
000014 3300                          cpi Rtmp0, '0'
000015 f030                          brlo NotDigit
                                 
000016 330a                          cpi Rtmp0, '9' + 1
000017 f420                          brsh NotDigit
                                 
                                     ; It IS a digit
000018 d02f                          rcall Handle_Digit
000019 d13b                          rcall WaitKeyRelease
00001a cff0                          rjmp MainLoop
                                 
                                 
                                 ;-------------------------------------
                                 ; This label is near the branch target
                                 ; So breq Rtmp0,'=' will always reach it
                                 ;-------------------------------------
                                 Equal_Near:
00001b c052                          rjmp Handle_Equal            ; long-range jump OK
                                 
                                 
                                 ;-------------------------------------
                                 NotDigit:
00001c d138                          rcall WaitKeyRelease
00001d cfed                          rjmp MainLoop
                                 
                                 ;-------------------------------------------
                                 ; CALCULATOR HANDLERS
                                 ;-------------------------------------------
                                 
                                 Handle_Clear:
00001e d083                          rcall ClearLCD
00001f d078                          rcall ResetCalc
000020 d134                          rcall WaitKeyRelease
000021 cfe9                          rjmp MainLoop
                                 
                                 Handle_Plus:
                                     ; if result already shown, start new calc
000022 9110 0102                     lds Rtmp1, STATE
000024 3012                          cpi Rtmp1, 2
000025 f411                          brne HP_NoRes
000026 d07b                          rcall ClearLCD
000027 d070                          rcall ResetCalc
                                 HP_NoRes:
000028 9110 0102                     lds Rtmp1, STATE
00002a 3010                          cpi Rtmp1, 0
00002b f439                          brne HP_Done              ; ignore if not in OP1 entry
                                 
00002c 9300 0103                     sts OPER, Rtmp0           ; store '+'
00002e 2f10                          mov Rtmp1, Rtmp0
00002f d0be                          rcall LCD_PutChar         ; show '+'
000030 e011                          ldi Rtmp1, 1
000031 9310 0102                     sts STATE, Rtmp1          ; now entering OP2
                                 HP_Done:
000033 d121                          rcall WaitKeyRelease
000034 cfd6                          rjmp MainLoop
                                 
                                 Handle_Minus:
000035 9110 0102                     lds Rtmp1, STATE
000037 3012                          cpi Rtmp1, 2
000038 f411                          brne HM_NoRes
000039 d068                          rcall ClearLCD
00003a d05d                          rcall ResetCalc
                                 HM_NoRes:
00003b 9110 0102                     lds Rtmp1, STATE
00003d 3010                          cpi Rtmp1, 0
00003e f439                          brne HM_Done
                                 
00003f 9300 0103                     sts OPER, Rtmp0           ; store '-'
000041 2f10                          mov Rtmp1, Rtmp0
000042 d0ab                          rcall LCD_PutChar
000043 e011                          ldi Rtmp1, 1
000044 9310 0102                     sts STATE, Rtmp1
                                 HM_Done:
000046 d10e                          rcall WaitKeyRelease
000047 cfc3                          rjmp MainLoop
                                 
                                 ; Rtmp0 = ASCII digit
                                 Handle_Digit:
                                     ; if result shown -> new expression
000048 9110 0102                     lds Rtmp1, STATE
00004a 3012                          cpi Rtmp1, 2
00004b f411                          brne HD_NoRes
00004c d055                          rcall ClearLCD
00004d d04a                          rcall ResetCalc
                                 HD_NoRes:
00004e 2f10                          mov Rtmp1, Rtmp0
00004f 5310                          subi Rtmp1, '0'        ; Rtmp1 = digit 0..9
                                 
000050 9120 0102                     lds Rtmp2, STATE
000052 3020                          cpi Rtmp2, 0
000053 f461                          brne HD_OP2
                                 
                                     ; ---- entering OP1 ----
000054 9120 0100                     lds Rtmp2, OP1         ; Rtmp2 = OP1
                                     ; OP1 = OP1*10 + digit
000056 2f32                          mov Rtmp3, Rtmp2
000057 0f22                          lsl Rtmp2              ; *2
000058 2f32                          mov Rtmp3, Rtmp2
000059 0f22                          lsl Rtmp2              ; *4
00005a 0f22                          lsl Rtmp2              ; *8
00005b 0f23                          add Rtmp2, Rtmp3       ; *10
00005c 0f21                          add Rtmp2, Rtmp1
00005d 9320 0100                     sts OP1, Rtmp2
00005f c00b                          rjmp HD_Print
                                 
                                 HD_OP2:
                                     ; ---- entering OP2 ----
000060 9120 0101                     lds Rtmp2, OP2
000062 2f32                          mov Rtmp3, Rtmp2
000063 0f22                          lsl Rtmp2
000064 2f32                          mov Rtmp3, Rtmp2
000065 0f22                          lsl Rtmp2
000066 0f22                          lsl Rtmp2
000067 0f23                          add Rtmp2, Rtmp3
000068 0f21                          add Rtmp2, Rtmp1
000069 9320 0101                     sts OP2, Rtmp2
                                 
                                 HD_Print:
00006b 2f10                          mov Rtmp1, Rtmp0
00006c d081                          rcall LCD_PutChar
00006d 9508                          ret
                                 
                                 ; '=' pressed, Rtmp0 = '='
                                 Handle_Equal:
                                     ; echo '=' on first line
00006e 2f10                          mov Rtmp1, Rtmp0
00006f d07e                          rcall LCD_PutChar
                                 
                                     ; load operator
000070 9110 0103                     lds Rtmp1, OPER
000072 321b                          cpi Rtmp1, '+'
000073 f021                          breq Do_Add
000074 321d                          cpi Rtmp1, '-'
000075 f049                          breq Do_Sub
                                 
                                     ; no operator -> ignore
000076 d0de                          rcall WaitKeyRelease
000077 cf93                          rjmp MainLoop
                                 
                                 ;------------ ADD -----------
                                 Do_Add:
000078 9140 0100                     lds Rval, OP1
00007a 9110 0101                     lds Rtmp1, OP2
00007c 0f41                          add Rval, Rtmp1            ; 0..198
00007d 2733                          clr Rtmp3                  ; sign flag = 0 (positive)
00007e c00d                          rjmp Show_Result
                                 
                                 ;------------ SUB -----------
                                 Do_Sub:
00007f 9110 0100                     lds Rtmp1, OP1
000081 9120 0101                     lds Rtmp2, OP2
000083 1712                          cp Rtmp1, Rtmp2
000084 f420                          brsh DS_Positive
                                 
                                     ; negative: VAL = OP2 - OP1, sign=1
000085 2f42                          mov Rval, Rtmp2
000086 1b41                          sub Rval, Rtmp1
000087 e031                          ldi Rtmp3, 1               ; sign negative
000088 c003                          rjmp Show_Result
                                 
                                 DS_Positive:
000089 2f41                          mov Rval, Rtmp1
00008a 1b42                          sub Rval, Rtmp2
00008b 2733                          clr Rtmp3                  ; sign positive
                                 
                                 Show_Result:
                                     ; move cursor to beginning of 2nd line
00008c ec00                          ldi Rtmp0, 0xC0
00008d d05a                          rcall LCD_Command
                                 
                                     ; if negative, print '-'
00008e 3031                          cpi Rtmp3, 1
00008f f411                          brne SR_NoMinus
000090 e21d                          ldi Rtmp1, '-'
000091 d05c                          rcall LCD_PutChar
                                 SR_NoMinus:
000092 d013                          rcall Print_0_199          ; print Rval
                                 
000093 e012                          ldi Rtmp1, 2
000094 9310 0102                     sts STATE, Rtmp1           ; result shown
000096 d0be                          rcall WaitKeyRelease
000097 cf73                          rjmp MainLoop
                                 
                                 ;-------------------------------------------
                                 ; CALCULATOR UTILITIES
                                 ;-------------------------------------------
                                 
                                 ResetCalc:
000098 e000                          ldi Rtmp0, 0
000099 9300 0100                     sts OP1,   Rtmp0
00009b 9300 0101                     sts OP2,   Rtmp0
00009d 9300 0103                     sts OPER,  Rtmp0
00009f 9300 0102                     sts STATE, Rtmp0
0000a1 9508                          ret
                                 
                                 ClearLCD:
0000a2 e001                          ldi Rtmp0, 0x01
0000a3 d044                          rcall LCD_Command
0000a4 d0bc                          rcall Delay_ms20
0000a5 9508                          ret
                                 
                                 ; Print Rval (0..199) as decimal
                                 Print_0_199:
                                     ; Rval holds value
0000a6 2711                          clr Rtmp1                 ; hundreds
                                 P100:
0000a7 3644                          cpi Rval, 100
0000a8 f018                          brlo P100Done
0000a9 5644                          subi Rval, 100
0000aa 9513                          inc Rtmp1
0000ab cffb                          rjmp P100
                                 P100Done:
                                 
0000ac 2722                          clr Rtmp2                 ; tens
                                 P10:
0000ad 304a                          cpi Rval, 10
0000ae f018                          brlo P10Done
0000af 504a                          subi Rval, 10
0000b0 9523                          inc Rtmp2
0000b1 cffb                          rjmp P10
                                 P10Done:
                                 
0000b2 e300                          ldi Rtmp0, '0'
                                 
                                     ; if hundreds >0 -> print H T U
0000b3 3010                          cpi Rtmp1, 0
0000b4 f079                          breq P_NoHund
                                 
0000b5 2f31                          mov Rtmp3, Rtmp1
0000b6 0f30                          add Rtmp3, Rtmp0
0000b7 2f13                          mov Rtmp1, Rtmp3
0000b8 d035                          rcall LCD_PutChar
                                 
0000b9 2f32                          mov Rtmp3, Rtmp2
0000ba e300                          ldi Rtmp0, '0'
0000bb 0f30                          add Rtmp3, Rtmp0
0000bc 2f13                          mov Rtmp1, Rtmp3
0000bd d030                          rcall LCD_PutChar
                                 
0000be 2f34                          mov Rtmp3, Rval
0000bf e300                          ldi Rtmp0, '0'
0000c0 0f30                          add Rtmp3, Rtmp0
0000c1 2f13                          mov Rtmp1, Rtmp3
0000c2 d02b                          rcall LCD_PutChar
0000c3 9508                          ret
                                 
                                 P_NoHund:
                                     ; if tens >0 -> print T U
0000c4 3020                          cpi Rtmp2, 0
0000c5 f021                          breq P_OnlyOnes
                                 
0000c6 2f32                          mov Rtmp3, Rtmp2
0000c7 0f30                          add Rtmp3, Rtmp0
0000c8 2f13                          mov Rtmp1, Rtmp3
0000c9 d024                          rcall LCD_PutChar
                                 
                                 P_OnlyOnes:
0000ca 2f34                          mov Rtmp3, Rval
0000cb e300                          ldi Rtmp0, '0'
0000cc 0f30                          add Rtmp3, Rtmp0
0000cd 2f13                          mov Rtmp1, Rtmp3
0000ce d01f                          rcall LCD_PutChar
0000cf 9508                          ret
                                 
                                 ;===========================================
                                 ; LCD & KEYPAD LOW-LEVEL
                                 ;===========================================
                                 
                                 Init_Ports:
                                     ; LCD data on PORTB
0000d0 ef0f                          ldi Rtmp0, 0xFF
0000d1 b904                          out DDRB, Rtmp0
0000d2 2700                          clr Rtmp0
0000d3 b905                          out PORTB, Rtmp0
                                 
                                     ; LCD control: RS=PC1, E=PC0
0000d4 9a38                          sbi DDRC, 0
0000d5 9a39                          sbi DDRC, 1
0000d6 9840                          cbi PORTC,0
0000d7 9841                          cbi PORTC,1
                                 
                                     ; Keypad: PD0..PD3 rows out, PD4..PD7 in+pull-up
0000d8 e00f                          ldi Rtmp0, 0x0F
0000d9 b90a                          out DDRD, Rtmp0
0000da ef00                          ldi Rtmp0, 0xF0
0000db 600f                          ori Rtmp0, 0x0F
0000dc b90b                          out PORTD, Rtmp0
0000dd 9508                          ret
                                 
                                 Init_LCD:
0000de e308                          ldi Rtmp0, 0x38        ; 8-bit, 2 lines
0000df d008                          rcall LCD_Command
0000e0 e00c                          ldi Rtmp0, 0x0C        ; display on, cursor off
0000e1 d006                          rcall LCD_Command
0000e2 e006                          ldi Rtmp0, 0x06        ; entry mode
0000e3 d004                          rcall LCD_Command
0000e4 e001                          ldi Rtmp0, 0x01        ; clear
0000e5 d002                          rcall LCD_Command
0000e6 d07a                          rcall Delay_ms20
0000e7 9508                          ret
                                 
                                 ; Rtmp0 = command
                                 LCD_Command:
0000e8 b905                          out PORTB, Rtmp0
0000e9 9841                          cbi PORTC,1            ; RS=0
0000ea 9a40                          sbi PORTC,0            ; E=1
0000eb 9840                          cbi PORTC,0            ; E=0
0000ec d070                          rcall Delay_us50
0000ed 9508                          ret
                                 
                                 ; Rtmp1 = data
                                 LCD_PutChar:
0000ee b915                          out PORTB, Rtmp1
0000ef 9a41                          sbi PORTC,1            ; RS=1
0000f0 9a40                          sbi PORTC,0            ; E=1
0000f1 9840                          cbi PORTC,0            ; E=0
0000f2 d06a                          rcall Delay_us50
0000f3 9508                          ret
                                 
                                 ;-------------------------------------------
                                 ; Keypad scanning – return ASCII in Rtmp0
                                 ;-------------------------------------------
                                 GetKeyBlocking:
                                 ScanLoop:
                                     ; Row1 low
0000f4 ef0e                          ldi Rtmp0, 0b11111110
0000f5 b90b                          out PORTD, Rtmp0
0000f6 d066                          rcall Delay_us50
0000f7 b119                          in  Rtmp1, PIND
0000f8 7f10                          andi Rtmp1, 0xF0
0000f9 3f10                          cpi Rtmp1, 0xF0
0000fa f4b1                          brne Row1
                                 
                                     ; Row2 low
0000fb ef0d                          ldi Rtmp0, 0b11111101
0000fc b90b                          out PORTD, Rtmp0
0000fd d05f                          rcall Delay_us50
0000fe b119                          in  Rtmp1, PIND
0000ff 7f10                          andi Rtmp1, 0xF0
000100 3f10                          cpi Rtmp1, 0xF0
000101 f4c1                          brne Row2
                                 
                                     ; Row3 low
000102 ef0b                          ldi Rtmp0, 0b11111011
000103 b90b                          out PORTD, Rtmp0
000104 d058                          rcall Delay_us50
000105 b119                          in  Rtmp1, PIND
000106 7f10                          andi Rtmp1, 0xF0
000107 3f10                          cpi Rtmp1, 0xF0
000108 f4d1                          brne Row3
                                 
                                     ; Row4 low
000109 ef07                          ldi Rtmp0, 0b11110111
00010a b90b                          out PORTD, Rtmp0
00010b d051                          rcall Delay_us50
00010c b119                          in  Rtmp1, PIND
00010d 7f10                          andi Rtmp1, 0xF0
00010e 3f10                          cpi Rtmp1, 0xF0
00010f f4e1                          brne Row4
                                 
000110 cfe3                          rjmp ScanLoop
                                 
                                 ; Row1: 7 8 9 /
                                 Row1:
000111 ff14                          sbrs Rtmp1,4
000112 c022                          rjmp K7
000113 ff15                          sbrs Rtmp1,5
000114 c022                          rjmp K8
000115 ff16                          sbrs Rtmp1,6
000116 c022                          rjmp K9
000117 ff17                          sbrs Rtmp1,7
000118 c022                          rjmp KDiv
000119 cfda                          rjmp ScanLoop
                                 
                                 ; Row2: 4 5 6 *
                                 Row2:
00011a ff14                          sbrs Rtmp1,4
00011b c021                          rjmp K4
00011c ff15                          sbrs Rtmp1,5
00011d c021                          rjmp K5
00011e ff16                          sbrs Rtmp1,6
00011f c021                          rjmp K6
000120 ff17                          sbrs Rtmp1,7
000121 c021                          rjmp KMul
000122 cfd1                          rjmp ScanLoop
                                 
                                 ; Row3: 1 2 3 -
                                 Row3:
000123 ff14                          sbrs Rtmp1,4
000124 c020                          rjmp K1
000125 ff15                          sbrs Rtmp1,5
000126 c020                          rjmp K2
000127 ff16                          sbrs Rtmp1,6
000128 c020                          rjmp K3
000129 ff17                          sbrs Rtmp1,7
00012a c020                          rjmp KMinus
00012b cfc8                          rjmp ScanLoop
                                 
                                 ; Row4: C 0 = +
                                 Row4:
00012c ff14                          sbrs Rtmp1,4
00012d c01f                          rjmp KC
00012e ff15                          sbrs Rtmp1,5
00012f c01f                          rjmp K0
000130 ff16                          sbrs Rtmp1,6
000131 c01f                          rjmp KEq
000132 ff17                          sbrs Rtmp1,7
000133 c01f                          rjmp KPlus
000134 cfbf                          rjmp ScanLoop
                                 
                                 ; key mapping (ASCII in Rtmp0)
                                 K7:
000135 e307                          ldi Rtmp0, '7'
000136 9508                          ret
                                 K8:
000137 e308                          ldi Rtmp0, '8'
000138 9508                          ret
                                 K9:
000139 e309                          ldi Rtmp0, '9'
00013a 9508                          ret
                                 KDiv:
00013b e20f                          ldi Rtmp0, '/'
00013c 9508                          ret
                                 
                                 K4:
00013d e304                          ldi Rtmp0, '4'
00013e 9508                          ret
                                 K5:
00013f e305                          ldi Rtmp0, '5'
000140 9508                          ret
                                 K6:
000141 e306                          ldi Rtmp0, '6'
000142 9508                          ret
                                 KMul:
000143 e20a                          ldi Rtmp0, '*'
000144 9508                          ret
                                 
                                 K1:
000145 e301                          ldi Rtmp0, '1'
000146 9508                          ret
                                 K2:
000147 e302                          ldi Rtmp0, '2'
000148 9508                          ret
                                 K3:
000149 e303                          ldi Rtmp0, '3'
00014a 9508                          ret
                                 KMinus:
00014b e20d                          ldi Rtmp0, '-'
00014c 9508                          ret
                                 
                                 KC:
00014d e403                          ldi Rtmp0, 'C'
00014e 9508                          ret
                                 K0:
00014f e300                          ldi Rtmp0, '0'
000150 9508                          ret
                                 KEq:
000151 e30d                          ldi Rtmp0, '='
000152 9508                          ret
                                 KPlus:
000153 e20b                          ldi Rtmp0, '+'
000154 9508                          ret
                                 
                                 ;-------------------------------------------
                                 ; Wait until all keys released
                                 ;-------------------------------------------
                                 WaitKeyRelease:
                                 ReleaseLoop:
000155 ef00                          ldi Rtmp0, 0b11110000       ; rows low, columns pull-up
