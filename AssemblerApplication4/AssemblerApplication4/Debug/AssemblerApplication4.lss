                                 ;===========================================
                                 
                                 ; ? 50 µs simple loop (rough, depends on F_CPU)
                                 Delay_us50:
00019d e258                          ldi Rdel0, 40
                                 Du_Loop:
00019e 955a                          dec Rdel0
00019f f7f1                          brne Du_Loop
0001a0 9508                          ret
                                 
                                 ; ? 20 ms by calling Delay_us50 many times
                                 Delay_ms20:
0001a1 ec68                          ldi Rdel1, 200
                                 Dm_Loop:
0001a2 dffa                          rcall Delay_us50
0001a3 956a                          dec Rdel1
0001a4 f7e9                          brne Dm_Loop
0001a5 9508                          ret
                                 


