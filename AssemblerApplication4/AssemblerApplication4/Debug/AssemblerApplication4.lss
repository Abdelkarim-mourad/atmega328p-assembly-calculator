                                 .equ	PAGESIZE	= 64
                                 .equ	FIRSTBOOTSTART	= 0x3f00
                                 .equ	SECONDBOOTSTART	= 0x3e00
                                 .equ	THIRDBOOTSTART	= 0x3c00
                                 .equ	FOURTHBOOTSTART	= 0x3800
                                 .equ	SMALLBOOTSTART	= FIRSTBOOTSTART
                                 .equ	LARGEBOOTSTART	= FOURTHBOOTSTART
                                 
                                 
                                 
                                 ; ***** INTERRUPT VECTORS ************************************************
                                 .equ	INT0addr	= 0x0002	; External Interrupt Request 0
                                 .equ	INT1addr	= 0x0004	; External Interrupt Request 1
                                 .equ	PCI0addr	= 0x0006	; Pin Change Interrupt Request 0
                                 .equ	PCI1addr	= 0x0008	; Pin Change Interrupt Request 0
                                 .equ	PCI2addr	= 0x000a	; Pin Change Interrupt Request 1
                                 .equ	WDTaddr	= 0x000c	; Watchdog Time-out Interrupt
                                 .equ	OC2Aaddr	= 0x000e	; Timer/Counter2 Compare Match A
                                 .equ	OC2Baddr	= 0x0010	; Timer/Counter2 Compare Match A
                                 .equ	OVF2addr	= 0x0012	; Timer/Counter2 Overflow
                                 .equ	ICP1addr	= 0x0014	; Timer/Counter1 Capture Event
                                 .equ	OC1Aaddr	= 0x0016	; Timer/Counter1 Compare Match A
                                 .equ	OC1Baddr	= 0x0018	; Timer/Counter1 Compare Match B
                                 .equ	OVF1addr	= 0x001a	; Timer/Counter1 Overflow
                                 .equ	OC0Aaddr	= 0x001c	; TimerCounter0 Compare Match A
                                 .equ	OC0Baddr	= 0x001e	; TimerCounter0 Compare Match B
                                 .equ	OVF0addr	= 0x0020	; Timer/Couner0 Overflow
                                 .equ	SPIaddr	= 0x0022	; SPI Serial Transfer Complete
                                 .equ	URXCaddr	= 0x0024	; USART Rx Complete
                                 .equ	UDREaddr	= 0x0026	; USART, Data Register Empty
                                 .equ	UTXCaddr	= 0x0028	; USART Tx Complete
                                 .equ	ADCCaddr	= 0x002a	; ADC Conversion Complete
                                 .equ	ERDYaddr	= 0x002c	; EEPROM Ready
                                 .equ	ACIaddr	= 0x002e	; Analog Comparator
                                 .equ	TWIaddr	= 0x0030	; Two-wire Serial Interface
                                 .equ	SPMRaddr	= 0x0032	; Store Program Memory Read
                                 
                                 .equ	INT_VECTORS_SIZE	= 52	; size in words
                                 
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 ; ATmega328P – 2-digit + / - * / calculator
                                 ; LCD 8-bit on PORTB, keypad on PORTD
                                 ; Software delays only
                                 ;===========================================
                                 
                                 .include "m328pdef.inc"
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega328P.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m328Pdef.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega328P
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega328P
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M328PDEF_INC_
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 ;-------------------------------------------
                                 ; Data section: variables in SRAM
                                 ;-------------------------------------------
                                 .dseg
000100                           OP1:    .byte 1      ; first operand (0..99)
000101                           OP2:    .byte 1      ; second operand (0..99)
000102                           STATE:  .byte 1      ; 0=enter OP1, 1=enter OP2, 2=result shown
000103                           OPER:   .byte 1      ; '+', '-', '*', '/'
                                 
                                 ;-------------------------------------------
                                 ; Code section
                                 ;-------------------------------------------
                                 .cseg
                                 .org 0x0000
000000 940c 0002                     jmp RESET        ; absolute jump, no range issue
                                 
                                 ; general purpose registers
                                 .def Rtmp0 = r16
                                 .def Rtmp1 = r17
                                 .def Rtmp2 = r18
                                 .def Rtmp3 = r19
                                 .def Rval  = r20     ; result / generic value
                                 .def Rdel0 = r21
                                 .def Rdel1 = r22
                                 .def Rrem = r23        ; safe remainder register
                                 .def Rdec = r24        ; decimal digit register
                                 
                                 ;-------------------------------------------
                                 ; RESET
                                 ;-------------------------------------------
                                 RESET:
                                     ; init stack
000002 e008                          ldi Rtmp0, HIGH(RAMEND)
000003 bf0e                          out SPH, Rtmp0
000004 ef0f                          ldi Rtmp0, LOW(RAMEND)
000005 bf0d                          out SPL, Rtmp0
                                 
000006 d109                          rcall Init_Ports
000007 d199                          rcall Delay_ms20
000008 d115                          rcall Init_LCD
                                 
000009 d0d8                          rcall ClearLCD
00000a d0cd                          rcall ResetCalc
                                 
                                 ;===========================================
                                 ; MAIN LOOP
                                 ;===========================================
                                 MainLoop:
00000b d128                          rcall GetKeyBlocking          ; ASCII key in Rtmp0
                                 
                                     ; ----- CLEAR (C) -----
00000c 3403                          cpi Rtmp0, 'C'
00000d f089                          breq KeyIsClear
                                 
                                     ; ----- operators + - * / -----
00000e 320b                          cpi Rtmp0, '+'
00000f f081                          breq KeyIsPlus
000010 320d                          cpi Rtmp0, '-'
000011 f071                          breq KeyIsMinus
000012 320a                          cpi Rtmp0, '*'
000013 f061                          breq KeyIsMul
000014 320f                          cpi Rtmp0, '/'
000015 f051                          breq KeyIsDiv
                                 
                                     ; ----- EQUAL (=) -----
000016 330d                          cpi Rtmp0, '='
000017 f049                          breq KeyIsEqual
                                 
                                     ; ----- DIGIT 0..9 ? -----
000018 3300                          cpi Rtmp0, '0'
000019 f040                          brlo NotDigit
                                 
00001a 330a                          cpi Rtmp0, '9'+1
00001b f430                          brsh NotDigit
                                 
                                     ; It IS a digit
00001c d01e                          rcall Handle_Digit
00001d d177                          rcall WaitKeyRelease
00001e cfec                          rjmp MainLoop
                                 
                                 ; local labels fed by branches (short distance)
                                 KeyIsClear:
00001f c004                          rjmp Handle_Clear
                                 
                                 KeyIsPlus:
                                 KeyIsMinus:
                                 KeyIsMul:
                                 KeyIsDiv:
000020 c007                          rjmp Handle_Operator        ; Rtmp0 already has '+','-','*','/'
                                 
                                 KeyIsEqual:
000021 c03f                          rjmp Handle_Equal
                                 
                                 NotDigit:
000022 d172                          rcall WaitKeyRelease
000023 cfe7                          rjmp MainLoop
                                 
                                 ;===========================================
                                 ; CALCULATOR HANDLERS
                                 ;===========================================
                                 
                                 ;-------------------------------------------
                                 ; Clear key: reset and clear screen
                                 ;-------------------------------------------
                                 Handle_Clear:
000024 d0bd                          rcall ClearLCD
000025 d0b2                          rcall ResetCalc
000026 d16e                          rcall WaitKeyRelease
000027 cfe3                          rjmp MainLoop
                                 
                                 ;-------------------------------------------
                                 ; Generic operator handler for + - * /
                                 ; Rtmp0 contains the operator char
                                 ;-------------------------------------------
                                 Handle_Operator:
                                     ; if result shown, start a new calculation
000028 9110 0102                     lds Rtmp1, STATE
00002a 3012                          cpi Rtmp1, 2
00002b f411                          brne Op_NoRes
00002c d0b5                          rcall ClearLCD
00002d d0aa                          rcall ResetCalc
                                 
                                 Op_NoRes:
                                     ; accept operator only right after OP1
00002e 9110 0102                     lds Rtmp1, STATE
000030 3010                          cpi Rtmp1, 0
000031 f439                          brne Op_Done         ; ignore if not in state 0
                                 
000032 9300 0103                     sts OPER, Rtmp0      ; store '+','-','*','/'
000034 2f10                          mov Rtmp1, Rtmp0
000035 d0f8                          rcall LCD_PutChar    ; show operator
                                 
000036 e011                          ldi Rtmp1, 1         ; now entering second operand
000037 9310 0102                     sts STATE, Rtmp1
                                 
                                 Op_Done:
000039 d15b                          rcall WaitKeyRelease
00003a cfd0                          rjmp MainLoop
                                 
                                 ;-------------------------------------------
                                 ; Digit key handler (multi-digit support)
                                 ; Rtmp0 = ASCII digit
                                 ;-------------------------------------------
                                 Handle_Digit:
                                     ; if a result is currently shown, start fresh
00003b 9110 0102                     lds Rtmp1, STATE
00003d 3012                          cpi Rtmp1, 2
00003e f411                          brne HD_NoRes
00003f d0a2                          rcall ClearLCD
000040 d097                          rcall ResetCalc
                                 HD_NoRes:
000041 2f10                          mov Rtmp1, Rtmp0
000042 5310                          subi Rtmp1, '0'      ; Rtmp1 = digit 0..9
                                 
                                     ; check which operand is being edited
000043 9120 0102                     lds Rtmp2, STATE
000045 3020                          cpi Rtmp2, 0
000046 f461                          brne HD_Op2
                                 
                                     ; ---- entering OP1 ----
000047 9120 0100                     lds Rtmp2, OP1       ; Rtmp2 = OP1
                                     ; OP1 = OP1*10 + digit  (x10 = x*8 + x*2)
000049 2f32                          mov Rtmp3, Rtmp2
00004a 0f22                          lsl Rtmp2            ; *2
00004b 2f32                          mov Rtmp3, Rtmp2
00004c 0f22                          lsl Rtmp2            ; *4
00004d 0f22                          lsl Rtmp2            ; *8
00004e 0f23                          add Rtmp2, Rtmp3     ; *10
00004f 0f21                          add Rtmp2, Rtmp1
000050 9320 0100                     sts OP1, Rtmp2
000052 c00b                          rjmp HD_Print
                                 
                                 HD_Op2:
                                     ; ---- entering OP2 ----
000053 9120 0101                     lds Rtmp2, OP2
000055 2f32                          mov Rtmp3, Rtmp2
000056 0f22                          lsl Rtmp2
000057 2f32                          mov Rtmp3, Rtmp2
000058 0f22                          lsl Rtmp2
000059 0f22                          lsl Rtmp2
00005a 0f23                          add Rtmp2, Rtmp3
00005b 0f21                          add Rtmp2, Rtmp1
00005c 9320 0101                     sts OP2, Rtmp2
                                 
                                 HD_Print:
00005e 2f10                          mov Rtmp1, Rtmp0
00005f d0ce                          rcall LCD_PutChar
000060 9508                          ret
                                 
                                 ;-------------------------------------------
                                 ; '=' key pressed
                                 ;-------------------------------------------
                                 Handle_Equal:
                                     ; echo '=' on first line
000061 2f10                          mov Rtmp1, Rtmp0
000062 d0cb                          rcall LCD_PutChar
                                 
                                     ; select operation based on OPER
000063 9110 0103                     lds Rtmp1, OPER
000065 321b                          cpi Rtmp1, '+'
000066 f041                          breq Do_Add
000067 321d                          cpi Rtmp1, '-'
000068 f069                          breq Do_Sub
000069 321a                          cpi Rtmp1, '*'
00006a f0c9                          breq Do_Mul
00006b 321f                          cpi Rtmp1, '/'
00006c f119                          breq Do_Div
                                 
                                     ; no valid operator -> ignore
00006d d127                          rcall WaitKeyRelease
00006e cf9c                          rjmp MainLoop
                                 
                                 ;------------ ADD : OP1 + OP2 -------------------
                                 Do_Add:
00006f 9140 0100                     lds Rval, OP1
000071 9110 0101                     lds Rtmp1, OP2
000073 0f41                          add Rval, Rtmp1            ; 0..198
000074 2733                          clr Rtmp3                  ; sign flag = 0 (positive)
000075 c056                          rjmp Show_Result
                                 
                                 ;------------ SUB : OP1 - OP2 -------------------
                                 Do_Sub:
000076 9110 0100                     lds Rtmp1, OP1
000078 9120 0101                     lds Rtmp2, OP2
00007a 1712                          cp Rtmp1, Rtmp2
00007b f420                          brsh DS_Positive
                                 
                                     ; negative: VAL = OP2 - OP1, sign=1
00007c 2f42                          mov Rval, Rtmp2
00007d 1b41                          sub Rval, Rtmp1
00007e e031                          ldi Rtmp3, 1               ; negative
00007f c04c                          rjmp Show_Result
                                 
                                 DS_Positive:
000080 2f41                          mov Rval, Rtmp1
000081 1b42                          sub Rval, Rtmp2
000082 2733                          clr Rtmp3                  ; positive
000083 c048                          rjmp Show_Result
                                 
                                 ;------------ MUL : OP1 * OP2 -------------------
                                 ; Simple repeated addition, enough for 1-digit or small numbers
                                 Do_Mul:
000084 9110 0100                     lds Rtmp1, OP1             ; multiplicand
000086 9120 0101                     lds Rtmp2, OP2             ; multiplier
000088 2744                          clr Rval                   ; result = 0
                                 
                                 Mul_Loop:
000089 3020                          cpi Rtmp2, 0
00008a f019                          breq Mul_Done
00008b 0f41                          add Rval, Rtmp1
00008c 952a                          dec Rtmp2
00008d cffb                          rjmp Mul_Loop
                                 
                                 Mul_Done:
00008e 2733                          clr Rtmp3                  ; always positive
00008f c03c                          rjmp Show_Result
                                 
                                 ;------------ DIV : OP1 / OP2 -------------------
                                 ; integer division (truncating); e.g. 7/3 = 2, 2/5 = 0
                                 Do_Div:
000090 9110 0100                     lds Rtmp1, OP1         ; A = dividend
000092 9120 0101                     lds Rtmp2, OP2         ; B = divisor
                                 
                                     ; check divide by zero
000094 3020                          cpi Rtmp2, 0
000095 f129                          breq Div_By_Zero
                                 
                                     ;----------------------------------
                                     ; 1) Compute integer part Q = A/B
                                     ;----------------------------------
000096 2744                          clr Rval               ; Q = 0
                                 Div_IntLoop:
000097 1712                          cp Rtmp1, Rtmp2
000098 f018                          brlo Div_IntDone
000099 1b12                          sub Rtmp1, Rtmp2
00009a 9543                          inc Rval
00009b cffb                          rjmp Div_IntLoop
                                 Div_IntDone:
                                 
                                     ; Save remainder safely into Rrem
00009c 2f71                          mov Rrem, Rtmp1        ; Rrem = R
                                 
                                     ;----------------------------------
                                     ; Print integer part
                                     ;----------------------------------
00009d ec00                          ldi Rtmp0, 0xC0
00009e d089                          rcall LCD_Command
                                 
00009f 2f34                          mov Rtmp3, Rval        ; Q
0000a0 e300                          ldi Rtmp0, '0'
0000a1 0f30                          add Rtmp3, Rtmp0
0000a2 2f13                          mov Rtmp1, Rtmp3
0000a3 d08a                          rcall LCD_PutChar
                                 
                                     ; print decimal point
0000a4 e21e                          ldi Rtmp1, '.'
0000a5 d088                          rcall LCD_PutChar
                                 
                                     ;----------------------------------
                                     ; 2) Compute decimal digit D = (R*10)/B
                                     ;----------------------------------
0000a6 2f37                          mov Rtmp3, Rrem        ; R = remainder
0000a7 e00a                          ldi Rtmp0, 10
0000a8 9f30                          mul Rtmp3, Rtmp0       ; R*10 -> r1:r0
0000a9 2d30                          mov Rtmp3, r0          ; take low byte
0000aa 2400                          clr r0
0000ab 2411                          clr r1
                                 
                                     ; divide (R*10) by B
0000ac 2788                          clr Rdec               ; decimal digit = 0
                                 Div_DecLoop:
0000ad 1732                          cp Rtmp3, Rtmp2
0000ae f018                          brlo Div_DecDone
0000af 1b32                          sub Rtmp3, Rtmp2
0000b0 9583                          inc Rdec
0000b1 cffb                          rjmp Div_DecLoop
                                 Div_DecDone:
                                 
                                     ;----------------------------------
                                     ; Print decimal digit (0..9)
                                     ;----------------------------------
0000b2 2f18                          mov Rtmp1, Rdec
0000b3 e300                          ldi Rtmp0, '0'
0000b4 0f10                          add Rtmp1, Rtmp0
0000b5 d078                          rcall LCD_PutChar
                                 
                                     ; finalize
0000b6 e012                          ldi Rtmp1, 2
0000b7 9310 0102                     sts STATE, Rtmp1
0000b9 d0db                          rcall WaitKeyRelease
0000ba cf50                          rjmp MainLoop
                                 
                                 ;------------ DIVIDE BY ZERO : show "ERROR" -----
                                 Div_By_Zero:
                                     ; go to second line
0000bb ec00                          ldi Rtmp0, 0xC0
0000bc d06b                          rcall LCD_Command
                                 
                                     ; print "ERROR"
0000bd e415                          ldi Rtmp1, 'E'
0000be d06f                          rcall LCD_PutChar
0000bf e512                          ldi Rtmp1, 'R'
0000c0 d06d                          rcall LCD_PutChar
0000c1 e512                          ldi Rtmp1, 'R'
0000c2 d06b                          rcall LCD_PutChar
0000c3 e41f                          ldi Rtmp1, 'O'
0000c4 d069                          rcall LCD_PutChar
0000c5 e512                          ldi Rtmp1, 'R'
0000c6 d067                          rcall LCD_PutChar
                                 
                                     ; mark state as result shown
0000c7 e012                          ldi Rtmp1, 2
0000c8 9310 0102                     sts STATE, Rtmp1
                                 
0000ca d0ca                          rcall WaitKeyRelease
0000cb cf3f                          rjmp MainLoop
                                 
                                 ;------------ Common result display -------------
                                 ; Rval contains magnitude (0..199)
                                 ; Rtmp3 = 0 positive, 1 negative (only used for subtraction)
                                 Show_Result:
                                     ; move cursor to second line
0000cc ec00                          ldi Rtmp0, 0xC0
0000cd d05a                          rcall LCD_Command
                                 
                                     ; print '-' if negative
0000ce 3031                          cpi Rtmp3, 1
0000cf f411                          brne SR_NoMinus
0000d0 e21d                          ldi Rtmp1, '-'
0000d1 d05c                          rcall LCD_PutChar
                                 SR_NoMinus:
0000d2 d013                          rcall Print_0_199          ; prints Rval
                                 
0000d3 e012                          ldi Rtmp1, 2
0000d4 9310 0102                     sts STATE, Rtmp1           ; result shown
                                 
0000d6 d0be                          rcall WaitKeyRelease
0000d7 cf33                          rjmp MainLoop
                                 
                                 ;===========================================
                                 ; CALCULATOR UTILITIES
                                 ;===========================================
                                 
                                 ResetCalc:
0000d8 e000                          ldi Rtmp0, 0
0000d9 9300 0100                     sts OP1,   Rtmp0
0000db 9300 0101                     sts OP2,   Rtmp0
0000dd 9300 0103                     sts OPER,  Rtmp0
0000df 9300 0102                     sts STATE, Rtmp0
0000e1 9508                          ret
                                 
                                 ClearLCD:
0000e2 e001                          ldi Rtmp0, 0x01
0000e3 d044                          rcall LCD_Command
0000e4 d0bc                          rcall Delay_ms20
0000e5 9508                          ret
                                 
                                 ; Print Rval (0..199) as decimal (no leading zeros)
                                 Print_0_199:
                                     ; Rval holds value
0000e6 2711                          clr Rtmp1                 ; hundreds
                                 P100:
0000e7 3644                          cpi Rval, 100
0000e8 f018                          brlo P100Done
0000e9 5644                          subi Rval, 100
0000ea 9513                          inc Rtmp1
0000eb cffb                          rjmp P100
                                 P100Done:
                                 
0000ec 2722                          clr Rtmp2                 ; tens
                                 P10:
0000ed 304a                          cpi Rval, 10
0000ee f018                          brlo P10Done
0000ef 504a                          subi Rval, 10
0000f0 9523                          inc Rtmp2
0000f1 cffb                          rjmp P10
                                 P10Done:
                                 
0000f2 e300                          ldi Rtmp0, '0'
                                 
                                     ; if hundreds>0 -> print H T U
0000f3 3010                          cpi Rtmp1, 0
0000f4 f079                          breq P_NoHund
                                 
0000f5 2f31                          mov Rtmp3, Rtmp1
0000f6 0f30                          add Rtmp3, Rtmp0
0000f7 2f13                          mov Rtmp1, Rtmp3
0000f8 d035                          rcall LCD_PutChar
                                 
0000f9 2f32                          mov Rtmp3, Rtmp2
0000fa e300                          ldi Rtmp0, '0'
0000fb 0f30                          add Rtmp3, Rtmp0
0000fc 2f13                          mov Rtmp1, Rtmp3
0000fd d030                          rcall LCD_PutChar
                                 
0000fe 2f34                          mov Rtmp3, Rval
0000ff e300                          ldi Rtmp0, '0'
000100 0f30                          add Rtmp3, Rtmp0
000101 2f13                          mov Rtmp1, Rtmp3
000102 d02b                          rcall LCD_PutChar
000103 9508                          ret
                                 
                                 P_NoHund:
                                     ; if tens>0 -> print T U
000104 3020                          cpi Rtmp2, 0
000105 f021                          breq P_OnlyOnes
                                 
000106 2f32                          mov Rtmp3, Rtmp2
000107 0f30                          add Rtmp3, Rtmp0
000108 2f13                          mov Rtmp1, Rtmp3
000109 d024                          rcall LCD_PutChar
                                 
                                 P_OnlyOnes:
00010a 2f34                          mov Rtmp3, Rval
00010b e300                          ldi Rtmp0, '0'
00010c 0f30                          add Rtmp3, Rtmp0
00010d 2f13                          mov Rtmp1, Rtmp3
00010e d01f                          rcall LCD_PutChar
00010f 9508                          ret
                                 
                                 ;===========================================
                                 ; LCD & KEYPAD LOW-LEVEL
                                 ;===========================================
                                 
                                 Init_Ports:
                                     ; LCD data on PORTB
000110 ef0f                          ldi Rtmp0, 0xFF
000111 b904                          out DDRB, Rtmp0
000112 2700                          clr Rtmp0
000113 b905                          out PORTB, Rtmp0
                                 
                                     ; LCD control RS=PC1, E=PC0
000114 9a38                          sbi DDRC, 0
000115 9a39                          sbi DDRC, 1
000116 9840                          cbi PORTC,0
000117 9841                          cbi PORTC,1
                                 
                                     ; Keypad: PD0..PD3 rows out, PD4..PD7 in with pull-ups
000118 e00f                          ldi Rtmp0, 0x0F
000119 b90a                          out DDRD, Rtmp0
00011a ef00                          ldi Rtmp0, 0xF0
00011b 600f                          ori Rtmp0, 0x0F
00011c b90b                          out PORTD, Rtmp0
00011d 9508                          ret
                                 
                                 Init_LCD:
00011e e308                          ldi Rtmp0, 0x38        ; 8-bit, 2 lines
00011f d008                          rcall LCD_Command
000120 e00c                          ldi Rtmp0, 0x0C        ; display on, cursor off
000121 d006                          rcall LCD_Command
000122 e006                          ldi Rtmp0, 0x06        ; entry mode
000123 d004                          rcall LCD_Command
000124 e001                          ldi Rtmp0, 0x01        ; clear
000125 d002                          rcall LCD_Command
000126 d07a                          rcall Delay_ms20
000127 9508                          ret
                                 
                                 ; Rtmp0 = command
                                 LCD_Command:
000128 b905                          out PORTB, Rtmp0
000129 9841                          cbi PORTC,1            ; RS=0
00012a 9a40                          sbi PORTC,0            ; E=1
00012b 9840                          cbi PORTC,0            ; E=0
00012c d070                          rcall Delay_us50
00012d 9508                          ret
                                 
                                 ; Rtmp1 = data
                                 LCD_PutChar:
00012e b915                          out PORTB, Rtmp1
00012f 9a41                          sbi PORTC,1            ; RS=1
000130 9a40                          sbi PORTC,0            ; E=1
000131 9840                          cbi PORTC,0            ; E=0
000132 d06a                          rcall Delay_us50
000133 9508                          ret
                                 
                                 ;-------------------------------------------
                                 ; Keypad scanning – return ASCII in Rtmp0
                                 ;-------------------------------------------
                                 GetKeyBlocking:
                                 ScanLoop:
                                     ; Row1 low
000134 ef0e                          ldi Rtmp0, 0b11111110
000135 b90b                          out PORTD, Rtmp0
000136 d066                          rcall Delay_us50
000137 b119                          in  Rtmp1, PIND
000138 7f10                          andi Rtmp1, 0xF0
000139 3f10                          cpi Rtmp1, 0xF0
00013a f4b1                          brne Row1
                                 
                                     ; Row2 low
