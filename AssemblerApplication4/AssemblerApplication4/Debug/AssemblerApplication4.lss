                                 ;-------------------------------------------
                                 ; Wait until all keys released
                                 ;-------------------------------------------
                                 WaitKeyRelease:
                                 ReleaseLoop:
000195 ef00                          ldi Rtmp0, 0b11110000       ; rows low, columns pull-up
000196 b90b                          out PORTD, Rtmp0
000197 d005                          rcall Delay_us50
000198 b119                          in  Rtmp1, PIND
000199 7f10                          andi Rtmp1, 0xF0
