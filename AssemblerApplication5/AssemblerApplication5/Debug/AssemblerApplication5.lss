                                 #pragma AVRPART MEMORY INT_SRAM SIZE 2048
                                 #pragma AVRPART MEMORY INT_SRAM START_ADDR 0x100
                                 
                                 
                                 
                                 ; ***** BOOTLOADER DECLARATIONS ******************************************
                                 .equ	NRWW_START_ADDR	= 0x3800
                                 .equ	NRWW_STOP_ADDR	= 0x3fff
                                 .equ	RWW_START_ADDR	= 0x0
                                 .equ	RWW_STOP_ADDR	= 0x37ff
                                 .equ	PAGESIZE	= 64
                                 .equ	FIRSTBOOTSTART	= 0x3f00
                                 .equ	SECONDBOOTSTART	= 0x3e00
                                 .equ	THIRDBOOTSTART	= 0x3c00
                                 .equ	FOURTHBOOTSTART	= 0x3800
                                 .equ	SMALLBOOTSTART	= FIRSTBOOTSTART
                                 .equ	LARGEBOOTSTART	= FOURTHBOOTSTART
                                 
                                 
                                 
                                 ; ***** INTERRUPT VECTORS ************************************************
                                 .equ	INT0addr	= 0x0002	; External Interrupt Request 0
                                 .equ	INT1addr	= 0x0004	; External Interrupt Request 1
                                 .equ	PCI0addr	= 0x0006	; Pin Change Interrupt Request 0
                                 .equ	PCI1addr	= 0x0008	; Pin Change Interrupt Request 0
                                 .equ	PCI2addr	= 0x000a	; Pin Change Interrupt Request 1
                                 .equ	WDTaddr	= 0x000c	; Watchdog Time-out Interrupt
                                 .equ	OC2Aaddr	= 0x000e	; Timer/Counter2 Compare Match A
                                 .equ	OC2Baddr	= 0x0010	; Timer/Counter2 Compare Match A
                                 .equ	OVF2addr	= 0x0012	; Timer/Counter2 Overflow
                                 .equ	ICP1addr	= 0x0014	; Timer/Counter1 Capture Event
                                 .equ	OC1Aaddr	= 0x0016	; Timer/Counter1 Compare Match A
                                 .equ	OC1Baddr	= 0x0018	; Timer/Counter1 Compare Match B
                                 .equ	OVF1addr	= 0x001a	; Timer/Counter1 Overflow
                                 .equ	OC0Aaddr	= 0x001c	; TimerCounter0 Compare Match A
                                 .equ	OC0Baddr	= 0x001e	; TimerCounter0 Compare Match B
                                 .equ	OVF0addr	= 0x0020	; Timer/Couner0 Overflow
                                 .equ	SPIaddr	= 0x0022	; SPI Serial Transfer Complete
                                 .equ	URXCaddr	= 0x0024	; USART Rx Complete
                                 .equ	UDREaddr	= 0x0026	; USART, Data Register Empty
                                 .equ	UTXCaddr	= 0x0028	; USART Tx Complete
                                 .equ	ADCCaddr	= 0x002a	; ADC Conversion Complete
                                 .equ	ERDYaddr	= 0x002c	; EEPROM Ready
                                 .equ	ACIaddr	= 0x002e	; Analog Comparator
                                 .equ	TWIaddr	= 0x0030	; Two-wire Serial Interface
                                 .equ	SPMRaddr	= 0x0032	; Store Program Memory Read
                                 
                                 .equ	INT_VECTORS_SIZE	= 52	; size in words
                                 
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 ; ATmega328P – 2-digit + / - * / calculator
                                 ; LCD 8-bit on PORTB, keypad on PORTD
                                 ; Software delays only
                                 ;===========================================
                                 
                                 .include "m328pdef.inc"
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega328P.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m328Pdef.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega328P
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega328P
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M328PDEF_INC_
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 ;-------------------------------------------
                                 ; Data section: variables in SRAM
                                 ;-------------------------------------------
                                 .dseg
000100                           OP1:    .byte 1      ; first operand (0..99)
000101                           OP2:    .byte 1      ; second operand (0..99)
000102                           STATE:  .byte 1      ; 0=enter OP1, 1=enter OP2, 2=result shown
000103                           OPER:   .byte 1      ; '+', '-', '*', '/'
                                 
                                 ;-------------------------------------------
                                 ; Code section
                                 ;-------------------------------------------
                                 .cseg
                                 .org 0x0000
000000 940c 0002                     jmp RESET        ; absolute jump, no range issue
                                 
                                 ; general purpose registers
                                 .def Rtmp0 = r16
                                 .def Rtmp1 = r17
                                 .def Rtmp2 = r18
                                 .def Rtmp3 = r19
                                 .def Rval  = r20     ; result / generic value
                                 .def Rdel0 = r21
                                 .def Rdel1 = r22
                                 .def RremLo = r23    ; 16-bit remainder/working value, low byte
                                 .def RremHi = r24    ; 16-bit remainder/working value, high byte
                                 .def Rdec1  = r25    ; first decimal digit (D1)
                                 .def Rdec2  = r26    ; second decimal digit (D2)
                                 .def Rzero = r27
                                 
                                 ;-------------------------------------------
                                 ; RESET
                                 ;-------------------------------------------
                                 RESET:
                                     ; init stack
000002 e008                          ldi Rtmp0, HIGH(RAMEND)
000003 bf0e                          out SPH, Rtmp0
000004 ef0f                          ldi Rtmp0, LOW(RAMEND)
000005 bf0d                          out SPL, Rtmp0
                                 
000006 d123                          rcall Init_Ports
000007 d1b3                          rcall Delay_ms20
000008 d12f                          rcall Init_LCD
                                 
000009 d0f2                          rcall ClearLCD
00000a d0e7                          rcall ResetCalc
00000b 27bb                      	clr Rzero
                                 
                                 ;===========================================
                                 ; MAIN LOOP
                                 ;===========================================
                                 MainLoop:
00000c d141                          rcall GetKeyBlocking          ; ASCII key in Rtmp0
                                 
                                     ; ----- CLEAR (C) -----
00000d 3403                          cpi Rtmp0, 'C'
00000e f089                          breq KeyIsClear
                                 
                                     ; ----- operators + - * / -----
00000f 320b                          cpi Rtmp0, '+'
000010 f081                          breq KeyIsPlus
000011 320d                          cpi Rtmp0, '-'
000012 f071                          breq KeyIsMinus
000013 320a                          cpi Rtmp0, '*'
000014 f061                          breq KeyIsMul
000015 320f                          cpi Rtmp0, '/'
000016 f051                          breq KeyIsDiv
                                 
                                     ; ----- EQUAL (=) -----
000017 330d                          cpi Rtmp0, '='
000018 f049                          breq KeyIsEqual
                                 
                                     ; ----- DIGIT 0..9 ? -----
000019 3300                          cpi Rtmp0, '0'
00001a f040                          brlo NotDigit
                                 
00001b 330a                          cpi Rtmp0, '9'+1
00001c f430                          brsh NotDigit
                                 
                                     ; It IS a digit
00001d d01e                          rcall Handle_Digit
00001e d190                          rcall WaitKeyRelease
00001f cfec                          rjmp MainLoop
                                 
                                 ; local labels fed by branches (short distance)
                                 KeyIsClear:
000020 c004                          rjmp Handle_Clear
                                 
                                 KeyIsPlus:
                                 KeyIsMinus:
                                 KeyIsMul:
                                 KeyIsDiv:
000021 c007                          rjmp Handle_Operator        ; Rtmp0 already has '+','-','*','/'
                                 
                                 KeyIsEqual:
000022 c03f                          rjmp Handle_Equal
                                 
                                 NotDigit:
000023 d18b                          rcall WaitKeyRelease
000024 cfe7                          rjmp MainLoop
                                 
                                 ;===========================================
                                 ; CALCULATOR HANDLERS
                                 ;===========================================
                                 
                                 ;-------------------------------------------
                                 ; Clear key: reset and clear screen
                                 ;-------------------------------------------
                                 Handle_Clear:
000025 d0d6                          rcall ClearLCD
000026 d0cb                          rcall ResetCalc
000027 d187                          rcall WaitKeyRelease
000028 cfe3                          rjmp MainLoop
                                 
                                 ;-------------------------------------------
                                 ; Generic operator handler for + - * /
                                 ; Rtmp0 contains the operator char
                                 ;-------------------------------------------
                                 Handle_Operator:
                                     ; if result shown, start a new calculation
000029 9110 0102                     lds Rtmp1, STATE
00002b 3012                          cpi Rtmp1, 2
00002c f411                          brne Op_NoRes
00002d d0ce                          rcall ClearLCD
00002e d0c3                          rcall ResetCalc
                                 
                                 Op_NoRes:
                                     ; accept operator only right after OP1
00002f 9110 0102                     lds Rtmp1, STATE
000031 3010                          cpi Rtmp1, 0
000032 f439                          brne Op_Done         ; ignore if not in state 0
                                 
000033 9300 0103                     sts OPER, Rtmp0      ; store '+','-','*','/'
000035 2f10                          mov Rtmp1, Rtmp0
000036 d111                          rcall LCD_PutChar    ; show operator
                                 
000037 e011                          ldi Rtmp1, 1         ; now entering second operand
000038 9310 0102                     sts STATE, Rtmp1
                                 
                                 Op_Done:
00003a d174                          rcall WaitKeyRelease
00003b cfd0                          rjmp MainLoop
                                 
                                 ;-------------------------------------------
                                 ; Digit key handler (multi-digit support)
                                 ; Rtmp0 = ASCII digit
                                 ;-------------------------------------------
                                 Handle_Digit:
                                     ; if a result is currently shown, start fresh
00003c 9110 0102                     lds Rtmp1, STATE
00003e 3012                          cpi Rtmp1, 2
00003f f411                          brne HD_NoRes
000040 d0bb                          rcall ClearLCD
000041 d0b0                          rcall ResetCalc
                                 HD_NoRes:
000042 2f10                          mov Rtmp1, Rtmp0
000043 5310                          subi Rtmp1, '0'      ; Rtmp1 = digit 0..9
                                 
                                     ; check which operand is being edited
000044 9120 0102                     lds Rtmp2, STATE
000046 3020                          cpi Rtmp2, 0
000047 f461                          brne HD_Op2
                                 
                                     ; ---- entering OP1 ----
000048 9120 0100                     lds Rtmp2, OP1       ; Rtmp2 = OP1
                                     ; OP1 = OP1*10 + digit  (x10 = x*8 + x*2)
00004a 2f32                          mov Rtmp3, Rtmp2
00004b 0f22                          lsl Rtmp2            ; *2
00004c 2f32                          mov Rtmp3, Rtmp2
00004d 0f22                          lsl Rtmp2            ; *4
00004e 0f22                          lsl Rtmp2            ; *8
00004f 0f23                          add Rtmp2, Rtmp3     ; *10
000050 0f21                          add Rtmp2, Rtmp1
000051 9320 0100                     sts OP1, Rtmp2
000053 c00b                          rjmp HD_Print
                                 
                                 HD_Op2:
                                     ; ---- entering OP2 ----
000054 9120 0101                     lds Rtmp2, OP2
000056 2f32                          mov Rtmp3, Rtmp2
000057 0f22                          lsl Rtmp2
000058 2f32                          mov Rtmp3, Rtmp2
000059 0f22                          lsl Rtmp2
00005a 0f22                          lsl Rtmp2
00005b 0f23                          add Rtmp2, Rtmp3
00005c 0f21                          add Rtmp2, Rtmp1
00005d 9320 0101                     sts OP2, Rtmp2
                                 
                                 HD_Print:
00005f 2f10                          mov Rtmp1, Rtmp0
000060 d0e7                          rcall LCD_PutChar
000061 9508                          ret
                                 
                                 ;-------------------------------------------
                                 ; '=' key pressed
                                 ;-------------------------------------------
                                 Handle_Equal:
                                     ; echo '=' on first line
000062 2f10                          mov Rtmp1, Rtmp0
000063 d0e4                          rcall LCD_PutChar
                                 
                                     ; select operation based on OPER
000064 9110 0103                     lds Rtmp1, OPER
000066 321b                          cpi Rtmp1, '+'
000067 f041                          breq Do_Add
000068 321d                          cpi Rtmp1, '-'
000069 f069                          breq Do_Sub
00006a 321a                          cpi Rtmp1, '*'
00006b f0c9                          breq Do_Mul
00006c 321f                          cpi Rtmp1, '/'
00006d f119                          breq Do_Div
                                 
                                     ; no valid operator -> ignore
00006e d140                          rcall WaitKeyRelease
00006f cf9c                          rjmp MainLoop
                                 
                                 ;------------ ADD : OP1 + OP2 -------------------
                                 Do_Add:
000070 9140 0100                     lds Rval, OP1
000072 9110 0101                     lds Rtmp1, OP2
000074 0f41                          add Rval, Rtmp1            ; 0..198
000075 2733                          clr Rtmp3                  ; sign flag = 0 (positive)
000076 c06f                          rjmp Show_Result
                                 
                                 ;------------ SUB : OP1 - OP2 -------------------
                                 Do_Sub:
000077 9110 0100                     lds Rtmp1, OP1
000079 9120 0101                     lds Rtmp2, OP2
00007b 1712                          cp Rtmp1, Rtmp2
00007c f420                          brsh DS_Positive
                                 
                                     ; negative: VAL = OP2 - OP1, sign=1
00007d 2f42                          mov Rval, Rtmp2
00007e 1b41                          sub Rval, Rtmp1
00007f e031                          ldi Rtmp3, 1               ; negative
000080 c065                          rjmp Show_Result
                                 
                                 DS_Positive:
000081 2f41                          mov Rval, Rtmp1
000082 1b42                          sub Rval, Rtmp2
000083 2733                          clr Rtmp3                  ; positive
000084 c061                          rjmp Show_Result
                                 
                                 ;------------ MUL : OP1 * OP2 -------------------
                                 ; Simple repeated addition, enough for 1-digit or small numbers
                                 Do_Mul:
000085 9110 0100                     lds Rtmp1, OP1             ; multiplicand
000087 9120 0101                     lds Rtmp2, OP2             ; multiplier
000089 2744                          clr Rval                   ; result = 0
                                 
                                 Mul_Loop:
00008a 3020                          cpi Rtmp2, 0
00008b f019                          breq Mul_Done
00008c 0f41                          add Rval, Rtmp1
00008d 952a                          dec Rtmp2
00008e cffb                          rjmp Mul_Loop
                                 
                                 Mul_Done:
00008f 2733                          clr Rtmp3                  ; always positive
000090 c055                          rjmp Show_Result
                                 
                                 ;------------ DIV : OP1 / OP2 -------------------
                                 ; integer division (truncating); e.g. 7/3 = 2, 2/5 = 0
                                 Do_Div:
                                     ; A = OP1 (dividend), B = OP2 (divisor)
000091 9110 0100                     lds Rtmp1, OP1           ; A
000093 9120 0101                     lds Rtmp2, OP2           ; B
                                 
                                     ; check divide by zero
000095 3020                          cpi Rtmp2, 0
000096 f1f1                          breq Div_By_Zero
                                 
                                     ;--------------------------------------
                                     ; 1) Integer part Q = A / B
                                     ;--------------------------------------
000097 2744                          clr Rval                 ; Q = 0
                                 Div_IntLoop:
000098 1712                          cp  Rtmp1, Rtmp2
000099 f018                          brlo Div_IntDone
00009a 1b12                          sub Rtmp1, Rtmp2
00009b 9543                          inc Rval
00009c cffb                          rjmp Div_IntLoop
                                 Div_IntDone:
                                     ; now:
                                     ;   Rval  = Q (integer part)
                                     ;   Rtmp1 = R (remainder)
                                 
                                     ;--------------------------------------
                                     ; Move cursor to second line
                                     ;--------------------------------------
00009d ec00                          ldi Rtmp0, 0xC0
00009e d0a3                          rcall LCD_Command
                                 
                                     ; print integer part Q (0..99 but in practice small)
00009f 2f34                          mov Rtmp3, Rval
0000a0 e300                          ldi Rtmp0, '0'
0000a1 0f30                          add Rtmp3, Rtmp0
0000a2 2f13                          mov Rtmp1, Rtmp3
0000a3 d0a4                          rcall LCD_PutChar
                                 
                                     ; print decimal point '.'
0000a4 e21e                          ldi Rtmp1, '.'
0000a5 d0a2                          rcall LCD_PutChar
                                 
                                     ;--------------------------------------
                                     ; 2) First decimal digit D1
                                     ;    D1 = floor( (R * 10) / B )
                                     ;    R1 = (R * 10) % B   (kept in RremHi:RremLo)
                                     ;--------------------------------------
                                 
                                     ; Rrem = R * 10 (16-bit) using repeated addition
0000a6 2777                          clr RremLo
0000a7 2788                          clr RremHi
0000a8 e09a                          ldi Rdec1, 10           ; use Rdec1 as loop counter here
                                 Mul10_D1_Loop:
0000a9 0f71                          add RremLo, Rtmp1
0000aa 1f8b                          adc RremHi, Rzero ; __zero_reg__ = r1 is always 0 in AVR-GCC,
                                                               ; if not using GCC, replace with a real zero reg
0000ab 959a                          dec Rdec1
0000ac f7e1                          brne Mul10_D1_Loop
                                 
                                     ; Now divide Rrem (16-bit) by B to get D1 and remainder
0000ad 2799                          clr Rdec1               ; Rdec1 will hold D1 (0..9)
                                 DivDec1_Check:
0000ae 3080                          cpi RremHi, 0
0000af f411                          brne DivDec1_DoSub
0000b0 1772                          cp  RremLo, Rtmp2
0000b1 f020                          brlo DivDec1_Done
                                 
                                 DivDec1_DoSub:
0000b2 1b72                          sub RremLo, Rtmp2
0000b3 0b8b                          sbc RremHi, Rzero
0000b4 9593                          inc Rdec1
0000b5 cff8                          rjmp DivDec1_Check
                                 
                                 DivDec1_Done:
                                     ; Rdec1 = D1, RremHi:RremLo = R1
                                 
                                     ;--------------------------------------
                                     ; 3) Second decimal digit D2
                                     ;    D2 = floor( (R1 * 10) / B )
                                     ;--------------------------------------
                                 
                                     ; multiply R1 (16-bit) by 10: Rrem = R1 * 10
0000b6 2f17                          mov Rtmp1, RremLo        ; copy R1 low
0000b7 2f38                          mov Rtmp3, RremHi        ; copy R1 high
0000b8 2777                          clr RremLo
0000b9 2788                          clr RremHi
0000ba e0aa                          ldi Rdec2, 10            ; loop counter for *10
                                 Mul10_D2_Loop:
0000bb 0f71                          add RremLo, Rtmp1
0000bc 1f83                          adc RremHi, Rtmp3
0000bd 95aa                          dec Rdec2
0000be f7e1                          brne Mul10_D2_Loop
                                 
                                     ; divide Rrem (16-bit) by B to get D2
0000bf 27aa                          clr Rdec2               ; will hold D2
                                 DivDec2_Check:
0000c0 3080                          cpi RremHi, 0
0000c1 f411                          brne DivDec2_DoSub
0000c2 1772                          cp  RremLo, Rtmp2
0000c3 f020                          brlo DivDec2_Done
                                 
                                 DivDec2_DoSub:
0000c4 1b72                          sub RremLo, Rtmp2
0000c5 0b8b                          sbc RremHi, Rzero
0000c6 95a3                          inc Rdec2
0000c7 cff8                          rjmp DivDec2_Check
                                 
                                 DivDec2_Done:
                                     ; Rdec1 = first decimal digit
                                     ; Rdec2 = second decimal digit
                                 
                                     ;--------------------------------------
                                     ; 4) Print D1 and D2
                                     ;--------------------------------------
0000c8 2f19                          mov Rtmp1, Rdec1
0000c9 e300                          ldi Rtmp0, '0'
0000ca 0f10                          add Rtmp1, Rtmp0
0000cb d07c                          rcall LCD_PutChar        ; print first decimal
                                 
0000cc 2f1a                          mov Rtmp1, Rdec2
0000cd e300                          ldi Rtmp0, '0'
0000ce 0f10                          add Rtmp1, Rtmp0
0000cf d078                          rcall LCD_PutChar        ; print second decimal
                                 
                                     ; mark result as shown
0000d0 e012                          ldi Rtmp1, 2
0000d1 9310 0102                     sts STATE, Rtmp1
                                 
0000d3 d0db                          rcall WaitKeyRelease
0000d4 cf37                          rjmp MainLoop
                                 
                                 ;------------ DIVIDE BY ZERO : show "ERROR" -----
                                 Div_By_Zero:
                                     ; go to second line
0000d5 ec00                          ldi Rtmp0, 0xC0
0000d6 d06b                          rcall LCD_Command
                                 
                                     ; print "ERROR"
0000d7 e415                          ldi Rtmp1, 'E'
0000d8 d06f                          rcall LCD_PutChar
0000d9 e512                          ldi Rtmp1, 'R'
0000da d06d                          rcall LCD_PutChar
0000db e512                          ldi Rtmp1, 'R'
0000dc d06b                          rcall LCD_PutChar
0000dd e41f                          ldi Rtmp1, 'O'
0000de d069                          rcall LCD_PutChar
0000df e512                          ldi Rtmp1, 'R'
0000e0 d067                          rcall LCD_PutChar
                                 
                                     ; mark state as result shown
0000e1 e012                          ldi Rtmp1, 2
0000e2 9310 0102                     sts STATE, Rtmp1
                                 
0000e4 d0ca                          rcall WaitKeyRelease
0000e5 cf26                          rjmp MainLoop
                                 
                                 ;------------ Common result display -------------
                                 ; Rval contains magnitude (0..199)
                                 ; Rtmp3 = 0 positive, 1 negative (only used for subtraction)
                                 Show_Result:
                                     ; move cursor to second line
0000e6 ec00                          ldi Rtmp0, 0xC0
0000e7 d05a                          rcall LCD_Command
                                 
                                     ; print '-' if negative
0000e8 3031                          cpi Rtmp3, 1
0000e9 f411                          brne SR_NoMinus
0000ea e21d                          ldi Rtmp1, '-'
0000eb d05c                          rcall LCD_PutChar
                                 SR_NoMinus:
0000ec d013                          rcall Print_0_199          ; prints Rval
                                 
0000ed e012                          ldi Rtmp1, 2
0000ee 9310 0102                     sts STATE, Rtmp1           ; result shown
                                 
0000f0 d0be                          rcall WaitKeyRelease
0000f1 cf1a                          rjmp MainLoop
                                 
                                 ;===========================================
                                 ; CALCULATOR UTILITIES
                                 ;===========================================
                                 
                                 ResetCalc:
0000f2 e000                          ldi Rtmp0, 0
0000f3 9300 0100                     sts OP1,   Rtmp0
0000f5 9300 0101                     sts OP2,   Rtmp0
0000f7 9300 0103                     sts OPER,  Rtmp0
0000f9 9300 0102                     sts STATE, Rtmp0
0000fb 9508                          ret
                                 
                                 ClearLCD:
0000fc e001                          ldi Rtmp0, 0x01
0000fd d044                          rcall LCD_Command
0000fe d0bc                          rcall Delay_ms20
0000ff 9508                          ret
                                 
                                 ; Print Rval (0..199) as decimal (no leading zeros)
                                 Print_0_199:
                                     ; Rval holds value
000100 2711                          clr Rtmp1                 ; hundreds
                                 P100:
000101 3644                          cpi Rval, 100
000102 f018                          brlo P100Done
000103 5644                          subi Rval, 100
000104 9513                          inc Rtmp1
000105 cffb                          rjmp P100
                                 P100Done:
                                 
000106 2722                          clr Rtmp2                 ; tens
                                 P10:
000107 304a                          cpi Rval, 10
000108 f018                          brlo P10Done
000109 504a                          subi Rval, 10
00010a 9523                          inc Rtmp2
00010b cffb                          rjmp P10
                                 P10Done:
                                 
00010c e300                          ldi Rtmp0, '0'
                                 
                                     ; if hundreds>0 -> print H T U
00010d 3010                          cpi Rtmp1, 0
00010e f079                          breq P_NoHund
                                 
00010f 2f31                          mov Rtmp3, Rtmp1
000110 0f30                          add Rtmp3, Rtmp0
000111 2f13                          mov Rtmp1, Rtmp3
000112 d035                          rcall LCD_PutChar
                                 
000113 2f32                          mov Rtmp3, Rtmp2
000114 e300                          ldi Rtmp0, '0'
000115 0f30                          add Rtmp3, Rtmp0
000116 2f13                          mov Rtmp1, Rtmp3
000117 d030                          rcall LCD_PutChar
                                 
000118 2f34                          mov Rtmp3, Rval
000119 e300                          ldi Rtmp0, '0'
00011a 0f30                          add Rtmp3, Rtmp0
00011b 2f13                          mov Rtmp1, Rtmp3
00011c d02b                          rcall LCD_PutChar
00011d 9508                          ret
                                 
                                 P_NoHund:
                                     ; if tens>0 -> print T U
00011e 3020                          cpi Rtmp2, 0
00011f f021                          breq P_OnlyOnes
                                 
000120 2f32                          mov Rtmp3, Rtmp2
000121 0f30                          add Rtmp3, Rtmp0
000122 2f13                          mov Rtmp1, Rtmp3
000123 d024                          rcall LCD_PutChar
                                 
                                 P_OnlyOnes:
000124 2f34                          mov Rtmp3, Rval
000125 e300                          ldi Rtmp0, '0'
000126 0f30                          add Rtmp3, Rtmp0
000127 2f13                          mov Rtmp1, Rtmp3
000128 d01f                          rcall LCD_PutChar
000129 9508                          ret
                                 
                                 ;===========================================
                                 ; LCD & KEYPAD LOW-LEVEL
                                 ;===========================================
                                 
                                 Init_Ports:
                                     ; LCD data on PORTB
00012a ef0f                          ldi Rtmp0, 0xFF
00012b b904                          out DDRB, Rtmp0
00012c 2700                          clr Rtmp0
00012d b905                          out PORTB, Rtmp0
                                 
                                     ; LCD control RS=PC1, E=PC0
00012e 9a38                          sbi DDRC, 0
00012f 9a39                          sbi DDRC, 1
000130 9840                          cbi PORTC,0
000131 9841                          cbi PORTC,1
                                 
                                     ; Keypad: PD0..PD3 rows out, PD4..PD7 in with pull-ups
000132 e00f                          ldi Rtmp0, 0x0F
000133 b90a                          out DDRD, Rtmp0
000134 ef00                          ldi Rtmp0, 0xF0
000135 600f                          ori Rtmp0, 0x0F
000136 b90b                          out PORTD, Rtmp0
000137 9508                          ret
                                 
                                 Init_LCD:
000138 e308                          ldi Rtmp0, 0x38        ; 8-bit, 2 lines
000139 d008                          rcall LCD_Command
00013a e00c                          ldi Rtmp0, 0x0C        ; display on, cursor off
00013b d006                          rcall LCD_Command
00013c e006                          ldi Rtmp0, 0x06        ; entry mode
00013d d004                          rcall LCD_Command
00013e e001                          ldi Rtmp0, 0x01        ; clear
00013f d002                          rcall LCD_Command
000140 d07a                          rcall Delay_ms20
000141 9508                          ret
                                 
                                 ; Rtmp0 = command
                                 LCD_Command:
000142 b905                          out PORTB, Rtmp0
000143 9841                          cbi PORTC,1            ; RS=0
000144 9a40                          sbi PORTC,0            ; E=1
000145 9840                          cbi PORTC,0            ; E=0
000146 d070                          rcall Delay_us50
000147 9508                          ret
                                 
                                 ; Rtmp1 = data
                                 LCD_PutChar:
000148 b915                          out PORTB, Rtmp1
000149 9a41                          sbi PORTC,1            ; RS=1
00014a 9a40                          sbi PORTC,0            ; E=1
00014b 9840                          cbi PORTC,0            ; E=0
00014c d06a                          rcall Delay_us50
00014d 9508                          ret
                                 
                                 ;-------------------------------------------
                                 ; Keypad scanning – return ASCII in Rtmp0
                                 ;-------------------------------------------
                                 GetKeyBlocking:
                                 ScanLoop:
                                     ; Row1 low
00014e ef0e                          ldi Rtmp0, 0b11111110
00014f b90b                          out PORTD, Rtmp0
000150 d066                          rcall Delay_us50
000151 b119                          in  Rtmp1, PIND
000152 7f10                          andi Rtmp1, 0xF0
000153 3f10                          cpi Rtmp1, 0xF0
000154 f4b1                          brne Row1
                                 
                                     ; Row2 low
000155 ef0d                          ldi Rtmp0, 0b11111101
000156 b90b                          out PORTD, Rtmp0
000157 d05f                          rcall Delay_us50
000158 b119                          in  Rtmp1, PIND
000159 7f10                          andi Rtmp1, 0xF0
00015a 3f10                          cpi Rtmp1, 0xF0
00015b f4c1                          brne Row2
                                 
                                     ; Row3 low
00015c ef0b                          ldi Rtmp0, 0b11111011
00015d b90b                          out PORTD, Rtmp0
00015e d058                          rcall Delay_us50
00015f b119                          in  Rtmp1, PIND
000160 7f10                          andi Rtmp1, 0xF0
000161 3f10                          cpi Rtmp1, 0xF0
000162 f4d1                          brne Row3
                                 
                                     ; Row4 low
000163 ef07                          ldi Rtmp0, 0b11110111
000164 b90b                          out PORTD, Rtmp0
000165 d051                          rcall Delay_us50
000166 b119                          in  Rtmp1, PIND
000167 7f10                          andi Rtmp1, 0xF0
000168 3f10                          cpi Rtmp1, 0xF0
000169 f4e1                          brne Row4
                                 
00016a cfe3                          rjmp ScanLoop
                                 
                                 ; Row1: 7 8 9 /
                                 Row1:
00016b ff14                          sbrs Rtmp1,4
00016c c022                          rjmp K7
00016d ff15                          sbrs Rtmp1,5
00016e c022                          rjmp K8
00016f ff16                          sbrs Rtmp1,6
000170 c022                          rjmp K9
000171 ff17                          sbrs Rtmp1,7
000172 c022                          rjmp KDiv
000173 cfda                          rjmp ScanLoop
                                 
                                 ; Row2: 4 5 6 *
                                 Row2:
000174 ff14                          sbrs Rtmp1,4
000175 c021                          rjmp K4
000176 ff15                          sbrs Rtmp1,5
000177 c021                          rjmp K5
000178 ff16                          sbrs Rtmp1,6
000179 c021                          rjmp K6
00017a ff17                          sbrs Rtmp1,7
00017b c021                          rjmp KMul
00017c cfd1                          rjmp ScanLoop
                                 
                                 ; Row3: 1 2 3 -
                                 Row3:
00017d ff14                          sbrs Rtmp1,4
00017e c020                          rjmp K1
00017f ff15                          sbrs Rtmp1,5
000180 c020                          rjmp K2
000181 ff16                          sbrs Rtmp1,6
000182 c020                          rjmp K3
000183 ff17                          sbrs Rtmp1,7
000184 c020                          rjmp KMinus
000185 cfc8                          rjmp ScanLoop
                                 
                                 ; Row4: C 0 = +
                                 Row4:
000186 ff14                          sbrs Rtmp1,4
000187 c01f                          rjmp KC
000188 ff15                          sbrs Rtmp1,5
000189 c01f                          rjmp K0
00018a ff16                          sbrs Rtmp1,6
00018b c01f                          rjmp KEq
00018c ff17                          sbrs Rtmp1,7
00018d c01f                          rjmp KPlus
00018e cfbf                          rjmp ScanLoop
                                 
                                 ; key mapping: ASCII in Rtmp0
                                 K7:
00018f e307                          ldi Rtmp0, '7'
000190 9508                          ret
                                 K8:
000191 e308                          ldi Rtmp0, '8'
000192 9508                          ret
                                 K9:
000193 e309                          ldi Rtmp0, '9'
000194 9508                          ret
                                 KDiv:
000195 e20f                          ldi Rtmp0, '/'
000196 9508                          ret
                                 
                                 K4:
000197 e304                          ldi Rtmp0, '4'
000198 9508                          ret
                                 K5:
000199 e305                          ldi Rtmp0, '5'
00019a 9508                          ret
                                 K6:
00019b e306                          ldi Rtmp0, '6'
00019c 9508                          ret
                                 KMul:
00019d e20a                          ldi Rtmp0, '*'
00019e 9508                          ret
                                 
                                 K1:
00019f e301                          ldi Rtmp0, '1'
0001a0 9508                          ret
                                 K2:
0001a1 e302                          ldi Rtmp0, '2'
0001a2 9508                          ret
                                 K3:
0001a3 e303                          ldi Rtmp0, '3'
0001a4 9508                          ret
                                 KMinus:
0001a5 e20d                          ldi Rtmp0, '-'
0001a6 9508                          ret
                                 
                                 KC:
0001a7 e403                          ldi Rtmp0, 'C'
0001a8 9508                          ret
                                 K0:
0001a9 e300                          ldi Rtmp0, '0'
0001aa 9508                          ret
                                 KEq:
0001ab e30d                          ldi Rtmp0, '='
0001ac 9508                          ret
                                 KPlus:
0001ad e20b                          ldi Rtmp0, '+'
0001ae 9508                          ret
                                 
                                 ;-------------------------------------------
                                 ; Wait until all keys released
                                 ;-------------------------------------------
                                 WaitKeyRelease:
                                 ReleaseLoop:
0001af ef00                          ldi Rtmp0, 0b11110000       ; rows low, columns pull-up
0001b0 b90b                          out PORTD, Rtmp0
0001b1 d005                          rcall Delay_us50
0001b2 b119                          in  Rtmp1, PIND
0001b3 7f10                          andi Rtmp1, 0xF0
0001b4 3f10                          cpi Rtmp1, 0xF0
0001b5 f7c9                          brne ReleaseLoop
0001b6 9508                          ret
                                 
                                 ;===========================================
                                 ; SOFTWARE DELAYS
                                 ;===========================================
                                 
                                 ; ? 50 µs simple loop (rough, depends on F_CPU)
                                 Delay_us50:
0001b7 e258                          ldi Rdel0, 40
                                 Du_Loop:
0001b8 955a                          dec Rdel0
0001b9 f7f1                          brne Du_Loop
0001ba 9508                          ret
                                 
                                 ; ? 20 ms by calling Delay_us50 many times
                                 Delay_ms20:
0001bb ec68                          ldi Rdel1, 200
                                 Dm_Loop:
0001bc dffa                          rcall Delay_us50
0001bd 956a                          dec Rdel1
0001be f7e9                          brne Dm_Loop
0001bf 9508                          ret
                                 
                                 


