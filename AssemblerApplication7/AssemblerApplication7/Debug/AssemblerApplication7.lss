                                 .equ	PAGESIZE	= 64
                                 .equ	FIRSTBOOTSTART	= 0x3f00
                                 .equ	SECONDBOOTSTART	= 0x3e00
                                 .equ	THIRDBOOTSTART	= 0x3c00
                                 .equ	FOURTHBOOTSTART	= 0x3800
                                 .equ	SMALLBOOTSTART	= FIRSTBOOTSTART
                                 .equ	LARGEBOOTSTART	= FOURTHBOOTSTART
                                 
                                 
                                 
                                 ; ***** INTERRUPT VECTORS ************************************************
                                 .equ	INT0addr	= 0x0002	; External Interrupt Request 0
                                 .equ	INT1addr	= 0x0004	; External Interrupt Request 1
                                 .equ	PCI0addr	= 0x0006	; Pin Change Interrupt Request 0
                                 .equ	PCI1addr	= 0x0008	; Pin Change Interrupt Request 0
                                 .equ	PCI2addr	= 0x000a	; Pin Change Interrupt Request 1
                                 .equ	WDTaddr	= 0x000c	; Watchdog Time-out Interrupt
                                 .equ	OC2Aaddr	= 0x000e	; Timer/Counter2 Compare Match A
                                 .equ	OC2Baddr	= 0x0010	; Timer/Counter2 Compare Match A
                                 .equ	OVF2addr	= 0x0012	; Timer/Counter2 Overflow
                                 .equ	ICP1addr	= 0x0014	; Timer/Counter1 Capture Event
                                 .equ	OC1Aaddr	= 0x0016	; Timer/Counter1 Compare Match A
                                 .equ	OC1Baddr	= 0x0018	; Timer/Counter1 Compare Match B
                                 .equ	OVF1addr	= 0x001a	; Timer/Counter1 Overflow
                                 .equ	OC0Aaddr	= 0x001c	; TimerCounter0 Compare Match A
                                 .equ	OC0Baddr	= 0x001e	; TimerCounter0 Compare Match B
                                 .equ	OVF0addr	= 0x0020	; Timer/Couner0 Overflow
                                 .equ	SPIaddr	= 0x0022	; SPI Serial Transfer Complete
                                 .equ	URXCaddr	= 0x0024	; USART Rx Complete
                                 .equ	UDREaddr	= 0x0026	; USART, Data Register Empty
                                 .equ	UTXCaddr	= 0x0028	; USART Tx Complete
                                 .equ	ADCCaddr	= 0x002a	; ADC Conversion Complete
                                 .equ	ERDYaddr	= 0x002c	; EEPROM Ready
                                 .equ	ACIaddr	= 0x002e	; Analog Comparator
                                 .equ	TWIaddr	= 0x0030	; Two-wire Serial Interface
                                 .equ	SPMRaddr	= 0x0032	; Store Program Memory Read
                                 
                                 .equ	INT_VECTORS_SIZE	= 52	; size in words
                                 
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 ; ATmega328P – 2-digit calculator 
                                 ; + - * / (division with 2 decimals) 
                                 ; LCD 8-bit on PORTB, keypad on PORTD 
                                 ; LM016L 16x2 
                                 ;=========================================== 
                                 .include "m328pdef.inc" 
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega328P.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m328Pdef.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega328P
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega328P
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M328PDEF_INC_
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 ;------------------------------------------- 
                                 ; Data section (SRAM variables) 
                                 ;------------------------------------------- 
                                 .dseg 
000100                           OP1: .byte 1 ; first operand (0..99) 
000101                           OP2: .byte 1 ; second operand (0..99) 
000102                           STATE: .byte 1 ; 0=enter OP1, 1=enter OP2, 2=result shown 
000103                           OPER: .byte 1 ; '+', '-', '*', '/' 
                                 
                                 ;------------------------------------------- 
                                 ; Code section 
                                 ;------------------------------------------- 
                                 .cseg 
                                 .org 0x0000 
000000 940c 0002                 jmp RESET ; absolute jump, safe range 
                                 
                                 ;------------------------------------------- 
                                 ; Register aliases 
                                 ;------------------------------------------- 
                                 .def Rzero = r15 ; constant 0 (we keep it cleared) 
                                 .def Rtmp0 = r16 
                                 .def Rtmp1 = r17 
                                 .def Rtmp2 = r18 
                                 .def Rtmp3 = r19 
                                 .def Rval = r20 ; result / generic 
                                 .def Rdel0 = r21 ; delay counter 
                                 .def Rdel1 = r22 ; delay counter 
                                 .def RremLo = r23 ; 16-bit remainder/working (low) 
                                 .def RremHi = r24 ; 16-bit remainder/working (high) 
                                 .def Rdec1 = r10 ; decimal digit 1 (FIXED: was r30)
                                 .def Rdec2 = r11 ; decimal digit 2 (FIXED: was r31)
                                 
                                 ;------------------------------------------- 
                                 ; RESET 
                                 ;------------------------------------------- 
                                 RESET: 
                                     ; init stack 
000002 e008                          ldi Rtmp0, HIGH(RAMEND) 
000003 bf0e                          out SPH, Rtmp0 
000004 ef0f                          ldi Rtmp0, LOW(RAMEND) 
000005 bf0d                          out SPL, Rtmp0 
                                 
000006 24ff                          clr Rzero ; make sure Rzero really is 0 
                                 
000007 d1ae                          rcall Init_Ports 
000008 d23e                          rcall Delay_ms20 
000009 d1ba                          rcall Init_LCD 
00000a d17d                          rcall ClearLCD 
00000b d172                          rcall ResetCalc 
                                 	    ; LCD control RS=PC1, E=PC0
00000c 9a38                          sbi DDRC, 0
00000d 9a39                          sbi DDRC, 1
                                 
                                     ; LED on PC2
00000e 9a3a                          sbi DDRC, 2        ; PC2 OUTPUT
00000f 9842                          cbi PORTC, 2       ; LED OFF initially
                                 
                                 
                                 ;=========================================== 
                                 ; MAIN LOOP 
                                 ;=========================================== 
                                 MainLoop: 
000010 d1c9                          rcall GetKeyBlocking ; ASCII key in Rtmp0 
                                 
                                     ; ----- CLEAR (C) ----- 
000011 3403                          cpi Rtmp0, 'C' 
000012 f089                          breq KeyIsClear 
                                 
                                     ; ----- operators + - * / ----- 
000013 320b                          cpi Rtmp0, '+' 
000014 f081                          breq KeyIsPlus 
000015 320d                          cpi Rtmp0, '-' 
000016 f071                          breq KeyIsMinus 
000017 320a                          cpi Rtmp0, '*' 
000018 f061                          breq KeyIsMul 
000019 320f                          cpi Rtmp0, '/' 
00001a f051                          breq KeyIsDiv 
                                 
                                     ; ----- EQUAL (=) ----- 
00001b 330d                          cpi Rtmp0, '=' 
00001c f049                          breq KeyIsEqual 
                                 
                                     ; ----- DIGIT 0..9 ? ----- 
00001d 3300                          cpi Rtmp0, '0' 
00001e f040                          brlo NotDigit 
00001f 330a                          cpi Rtmp0, '9'+1 
000020 f430                          brsh NotDigit 
                                 
                                     ; It IS a digit 
000021 d021                          rcall Handle_Digit 
000022 d218                          rcall WaitKeyRelease 
000023 cfec                          rjmp MainLoop 
                                 
                                 KeyIsClear: 
000024 c004                          rjmp Handle_Clear 
                                 
                                 KeyIsPlus: 
                                 KeyIsMinus: 
                                 KeyIsMul: 
                                 KeyIsDiv: 
000025 c009                          rjmp Handle_Operator ; Rtmp0 has '+','-','*','/' 
                                 
                                 KeyIsEqual: 
000026 c042                          rjmp Handle_Equal 
                                 
                                 NotDigit: 
000027 d213                          rcall WaitKeyRelease 
000028 cfe7                          rjmp MainLoop 
                                 
                                 ;=========================================== 
                                 ; CALCULATOR HANDLERS 
                                 ;=========================================== 
                                 
                                 ;------------------------------------------- 
                                 ; Clear key handler 
                                 ;------------------------------------------- 
                                 Handle_Clear: 
000029 9842                          cbi PORTC, 2       ; LED OFF
00002a d15d                          rcall ClearLCD 
00002b d152                          rcall ResetCalc 
00002c d20e                          rcall WaitKeyRelease 
00002d 940c 0010                     jmp MainLoop 
                                 
                                 ;------------------------------------------- 
                                 ; Generic operator handler (+ - * /) 
                                 ; Rtmp0 contains operator character 
                                 ;------------------------------------------- 
                                 Handle_Operator: 
                                     ; if result already shown, start new calc 
00002f 9110 0102                     lds Rtmp1, STATE 
000031 3012                          cpi Rtmp1, 2 
000032 f411                          brne Op_NoRes 
000033 d154                          rcall ClearLCD 
000034 d149                          rcall ResetCalc 
                                 
                                 Op_NoRes: 
                                     ; only accept operator when entering OP1 
000035 9110 0102                     lds Rtmp1, STATE 
000037 3010                          cpi Rtmp1, 0 
000038 f439                          brne Op_Done ; ignore if not state 0 
                                 
000039 9300 0103                     sts OPER, Rtmp0 ; store '+','-','*','/' 
00003b 2f10                          mov Rtmp1, Rtmp0 
00003c d197                          rcall LCD_PutChar ; show operator 
                                 
00003d e011                          ldi Rtmp1, 1 ; now entering OP2 
00003e 9310 0102                     sts STATE, Rtmp1 
                                 
                                 Op_Done: 
000040 d1fa                          rcall WaitKeyRelease 
000041 940c 0010                     jmp MainLoop 
                                 
                                 ;------------------------------------------- 
                                 ; Digit handler (multi-digit) 
                                 ; Rtmp0 = ASCII digit 
                                 ;------------------------------------------- 
                                 Handle_Digit: 
                                     ; if result shown, clear and restart 
000043 9110 0102                     lds Rtmp1, STATE 
000045 3012                          cpi Rtmp1, 2 
000046 f411                          brne HD_NoRes 
000047 d140                          rcall ClearLCD 
000048 d135                          rcall ResetCalc 
                                 
                                 HD_NoRes: 
000049 2f10                          mov Rtmp1, Rtmp0 
00004a 5310                          subi Rtmp1, '0' ; Rtmp1 = digit 0..9 
                                 
00004b 9120 0102                     lds Rtmp2, STATE 
00004d 3020                          cpi Rtmp2, 0 
00004e f461                          brne HD_Op2 
                                 
                                     ; ---- entering OP1 ---- 
00004f 9120 0100                     lds Rtmp2, OP1 ; Rtmp2 = OP1 
000051 2f32                          mov Rtmp3, Rtmp2 
000052 0f22                          lsl Rtmp2 ; *2 
000053 2f32                          mov Rtmp3, Rtmp2 
000054 0f22                          lsl Rtmp2 ; *4 
000055 0f22                          lsl Rtmp2 ; *8 
000056 0f23                          add Rtmp2, Rtmp3 ; *10 
000057 0f21                          add Rtmp2, Rtmp1 
000058 9320 0100                     sts OP1, Rtmp2 
00005a c00b                          rjmp HD_Print 
                                 
                                 HD_Op2: 
                                     ; ---- entering OP2 ---- 
00005b 9120 0101                     lds Rtmp2, OP2 
00005d 2f32                          mov Rtmp3, Rtmp2 
00005e 0f22                          lsl Rtmp2 
00005f 2f32                          mov Rtmp3, Rtmp2 
000060 0f22                          lsl Rtmp2 
000061 0f22                          lsl Rtmp2 
000062 0f23                          add Rtmp2, Rtmp3 
000063 0f21                          add Rtmp2, Rtmp1 
000064 9320 0101                     sts OP2, Rtmp2 
                                 
                                 HD_Print: 
000066 2f10                          mov Rtmp1, Rtmp0 
000067 d16c                          rcall LCD_PutChar 
000068 9508                          ret 
                                 
                                 ;------------------------------------------- 
                                 ; '=' pressed 
                                 ;------------------------------------------- 
                                 Handle_Equal: 
                                     ; echo '=' on line 1 
000069 2f10                          mov Rtmp1, Rtmp0 
00006a d169                          rcall LCD_PutChar 
                                 
                                     ; choose operator 
00006b 9110 0103                     lds Rtmp1, OPER 
00006d 321b                          cpi Rtmp1, '+' 
00006e f411                          brne NotAdd
00006f 940c 0080                     jmp Do_Add
                                 NotAdd:
000071 321d                          cpi Rtmp1, '-' 
000072 f411                          brne NotSub
000073 940c 0088                     jmp Do_Sub
                                 NotSub:
000075 321a                          cpi Rtmp1, '*' 
000076 f411                          brne NotMul
000077 940c 0098                     jmp Do_Mul
                                 NotMul:
000079 321f                          cpi Rtmp1, '/' 
00007a f411                          brne NotDiv
00007b 940c 0116                     jmp Do_Div
                                 NotDiv: 
                                 
                                     ; no valid operator 
00007d d1bd                          rcall WaitKeyRelease 
00007e 940c 0010                     jmp MainLoop 
                                 
                                 ;------------ ADD : OP1 + OP2 ------------------- 
                                 Do_Add: 
000080 9140 0100                     lds Rval, OP1 
000082 9110 0101                     lds Rtmp1, OP2 
000084 0f41                          add Rval, Rtmp1 ; 0..198 
000085 2733                          clr Rtmp3 ; sign = positive 
000086 940c 0171                     jmp Show_Result 
                                 
                                 ;------------ SUB : OP1 - OP2 ------------------- 
                                 Do_Sub: 
000088 9110 0100                     lds Rtmp1, OP1 
00008a 9120 0101                     lds Rtmp2, OP2 
00008c 1712                          cp Rtmp1, Rtmp2 
00008d f428                          brsh DS_Positive 
                                 
                                     ; negative result 
00008e 2f42                          mov Rval, Rtmp2 
00008f 1b41                          sub Rval, Rtmp1 
000090 e031                          ldi Rtmp3, 1 ; sign = negative 
000091 940c 0171                     jmp Show_Result 
                                 
                                 DS_Positive: 
000093 2f41                          mov Rval, Rtmp1 
000094 1b42                          sub Rval, Rtmp2 
000095 2733                          clr Rtmp3 ; sign = positive 
000096 940c 0171                     jmp Show_Result 
                                 
                                 ;------------ MUL : OP1 * OP2 (2-digit × 2-digit) -------------------
                                 ; Handles up to 99 × 99 = 9801
                                 ; Uses hardware MUL instruction for 8-bit × 8-bit = 16-bit result
                                 ;-----------------------------------------------------------------------
                                 Do_Mul:
000098 9110 0100                     lds     Rtmp1, OP1          ; multiplicand (0..99)
00009a 9120 0101                     lds     Rtmp2, OP2          ; multiplier (0..99)
                                     
                                     ; Use AVR's hardware MUL instruction
00009c 9f12                          mul     Rtmp1, Rtmp2        ; r1:r0 = OP1 × OP2
                                     
                                     ; Save result immediately
00009d 2d70                          mov     RremLo, r0          
00009e 2d81                          mov     RremHi, r1          
00009f 2411                          clr     r1                  ; clear r1 after mul
                                     
                                     ; Move to second line
0000a0 ec00                          ldi     Rtmp0, 0xC0
0000a1 d12c                          rcall   LCD_Command
                                     
                                     ; Convert 16-bit to decimal using division by 10
                                     ; We'll build digits from right to left
0000a2 d006                          rcall   Print_16bit_0_9999_NoR10R11
                                     
                                     ; Mark result as shown
0000a3 e012                          ldi     Rtmp1, 2
0000a4 9310 0102                     sts     STATE, Rtmp1
                                     
0000a6 d194                          rcall   WaitKeyRelease
0000a7 940c 0010                     jmp     MainLoop
                                 
                                 ;---------------------------------------------------------
                                 ; Print_16bit_0_9999_NoR10R11
                                 ; Prints unsigned 16-bit value in RremHi:RremLo (0..9999)
                                 ; No leading zeros (prints 0 correctly)
                                 ; Uses: Rtmp0,Rtmp1,Rtmp2,Rtmp3, RremHi,RremLo, Rzero
                                 ; DOES NOT TOUCH: r10, r11
                                 ;---------------------------------------------------------
                                 Print_16bit_0_9999_NoR10R11:
0000a9 2711                          clr Rtmp1                  ; thousands digit (0..9)
                                 
                                 ; ----- thousands loop: while value >= 1000 -----
                                 P16_1000_loop:
0000aa 3083                          cpi RremHi, 0x03
0000ab f038                          brlo P16_1000_done
0000ac f411                          brne P16_1000_sub
0000ad 3e78                          cpi RremLo, 0xE8           ; 0x03E8 = 1000
0000ae f020                          brlo P16_1000_done
                                 
                                 P16_1000_sub:
0000af 5e78                          subi RremLo, 0xE8
0000b0 4083                          sbci RremHi, 0x03
0000b1 9513                          inc  Rtmp1
0000b2 cff7                          rjmp P16_1000_loop
                                 
                                 P16_1000_done:
0000b3 2722                          clr Rtmp2                  ; hundreds digit (0..9)
                                 
                                 ; ----- hundreds loop: while value >= 100 -----
                                 P16_100_loop:
0000b4 2388                          tst RremHi                 ; if high != 0 => value >= 256 >= 100
0000b5 f411                          brne P16_100_sub
0000b6 3674                          cpi RremLo, 100
0000b7 f020                          brlo P16_100_done
                                 
                                 P16_100_sub:
0000b8 5674                          subi RremLo, 100
0000b9 4080                          sbci RremHi, 0
0000ba 9523                          inc  Rtmp2
0000bb cff8                          rjmp P16_100_loop
                                 
                                 P16_100_done:
0000bc 2733                          clr Rtmp3                  ; tens digit (0..9)
                                 
                                 ; ----- tens loop: while value >= 10 -----
                                 P16_10_loop:
0000bd 2388                          tst RremHi                 ; if high != 0 => value >= 256 >= 10
0000be f411                          brne P16_10_sub
0000bf 307a                          cpi RremLo, 10
0000c0 f020                          brlo P16_10_done
                                 
                                 P16_10_sub:
0000c1 507a                          subi RremLo, 10
0000c2 4080                          sbci RremHi, 0
0000c3 9533                          inc  Rtmp3
0000c4 cff8                          rjmp P16_10_loop
                                 
                                 P16_10_done:
                                     ; ones digit now in RremLo (0..9)
                                 
0000c5 e300                          ldi Rtmp0, '0'
                                 
                                     ; if thousands != 0 -> print thousands, hundreds, tens, ones
0000c6 3010                          cpi Rtmp1, 0
0000c7 f081                          breq P16_no_thousands
                                 
                                     ; thousands
0000c8 2f11                          mov Rtmp1, Rtmp1
0000c9 0f10                          add Rtmp1, Rtmp0
0000ca d109                          rcall LCD_PutChar
                                 
                                     ; hundreds (always)
0000cb 2f12                          mov Rtmp1, Rtmp2
0000cc e300                          ldi Rtmp0, '0'
0000cd 0f10                          add Rtmp1, Rtmp0
0000ce d105                          rcall LCD_PutChar
                                 
                                     ; tens (always)
0000cf 2f13                          mov Rtmp1, Rtmp3
0000d0 e300                          ldi Rtmp0, '0'
0000d1 0f10                          add Rtmp1, Rtmp0
0000d2 d101                          rcall LCD_PutChar
                                 
                                     ; ones
0000d3 2f17                          mov Rtmp1, RremLo
0000d4 e300                          ldi Rtmp0, '0'
0000d5 0f10                          add Rtmp1, Rtmp0
0000d6 d0fd                          rcall LCD_PutChar
0000d7 9508                          ret
                                 
                                 P16_no_thousands:
                                     ; if hundreds != 0 -> print hundreds, tens, ones
0000d8 3020                          cpi Rtmp2, 0
0000d9 f061                          breq P16_no_hundreds
                                 
0000da 2f12                          mov Rtmp1, Rtmp2
0000db 0f10                          add Rtmp1, Rtmp0
0000dc d0f7                          rcall LCD_PutChar
                                 
                                     ; tens (always)
0000dd 2f13                          mov Rtmp1, Rtmp3
0000de e300                          ldi Rtmp0, '0'
0000df 0f10                          add Rtmp1, Rtmp0
0000e0 d0f3                          rcall LCD_PutChar
                                 
                                     ; ones
0000e1 2f17                          mov Rtmp1, RremLo
0000e2 e300                          ldi Rtmp0, '0'
0000e3 0f10                          add Rtmp1, Rtmp0
0000e4 d0ef                          rcall LCD_PutChar
0000e5 9508                          ret
                                 
                                 P16_no_hundreds:
                                     ; if tens != 0 -> print tens, ones
0000e6 3030                          cpi Rtmp3, 0
0000e7 f019                          breq P16_only_ones
                                 
0000e8 2f13                          mov Rtmp1, Rtmp3
0000e9 0f10                          add Rtmp1, Rtmp0
0000ea d0e9                          rcall LCD_PutChar
                                 
                                 P16_only_ones:
                                     ; ones always
0000eb 2f17                          mov Rtmp1, RremLo
0000ec e300                          ldi Rtmp0, '0'
0000ed 0f10                          add Rtmp1, Rtmp0
0000ee d0e5                          rcall LCD_PutChar
0000ef 9508                          ret
                                 
                                 
                                 ;-----------------------------------------------------------------------
                                 ; Div16_by_10: Divide 16-bit RremHi:RremLo by 10
                                 ; Returns: quotient in RremHi:RremLo, remainder in Rtmp0
                                 ; Destroys: Rtmp0, Rtmp1
                                 ;-----------------------------------------------------------------------
                                 Div16_by_10:
0000f0 2700                          clr     Rtmp0               ; remainder = 0
0000f1 2711                          clr     Rtmp1               ; quotient high = 0
                                     
                                     ; We'll do 16-bit / 8-bit division manually
                                     ; Divide high byte first
0000f2 2f18                          mov     Rtmp1, RremHi       ; dividend high
0000f3 2788                          clr     RremHi              ; clear quotient high
                                     
                                 D10_High:
0000f4 301a                          cpi     Rtmp1, 10           ; is dividend >= 10?
0000f5 f018                          brlo    D10_High_Done
0000f6 501a                          subi    Rtmp1, 10
0000f7 9583                          inc     RremHi              ; increment quotient
0000f8 cffb                          rjmp    D10_High
                                     
                                 D10_High_Done:
                                     ; Rtmp1 now has remainder from high byte division
                                     ; This becomes high part of next dividend
                                     
                                     ; Now process low byte with carry from high
0000f9 2f01                          mov     Rtmp0, Rtmp1        ; carry from high byte
                                     
                                     ; Build 16-bit dividend: Rtmp0 (remainder from high) * 256 + RremLo
                                     ; But we can't multiply by 256 easily, so we'll do repeated subtraction
                                     ; Actually, let's use a simpler approach:
                                     
                                     ; Multiply remainder by 256/10 conceptually...
                                     ; Better: do it digit by digit
                                     
                                     ; Convert remainder*256 + low into decimal division
                                     ; remainder (0-9) * 256 = 0, 256, 512, 768, 1024, 1280, 1536, 1792, 2048, 2304
                                     ; For each case, calculate (remainder*256 + RremLo) / 10
                                     
                                     ; Simpler approach: shift and subtract
0000fa e110                          ldi     Rtmp1, 16           ; 16 bits to process
0000fb 2700                          clr     Rtmp0               ; remainder accumulator
                                     
                                 D10_Loop:
                                     ; Shift left RremHi:RremLo into Rtmp0
0000fc 0f77                          lsl     RremLo              ; shift low byte left
0000fd 1f88                          rol     RremHi              ; shift high byte left with carry
0000fe 1f00                          rol     Rtmp0               ; shift remainder left with carry
                                     
                                     ; Check if remainder >= 10
0000ff 300a                          cpi     Rtmp0, 10
000100 f010                          brlo    D10_Next
                                     
                                     ; Subtract 10 from remainder and set bit in quotient
000101 500a                          subi    Rtmp0, 10
000102 9573                          inc     RremLo              ; set LSB of quotient
                                     
                                 D10_Next:
000103 951a                          dec     Rtmp1
000104 f7b9                          brne    D10_Loop
                                     
                                     ; Rtmp0 now contains final remainder (0-9)
                                     ; RremHi:RremLo contains quotient
000105 9508                          ret
                                 
                                 Mul_Overflow:
                                     ; Result > 9999, show "OVER"
000106 ec00                          ldi     Rtmp0, 0xC0
000107 d0c6                          rcall   LCD_Command
                                     
000108 e41f                          ldi     Rtmp1, 'O'
000109 d0ca                          rcall   LCD_PutChar
00010a e516                          ldi     Rtmp1, 'V'
00010b d0c8                          rcall   LCD_PutChar
00010c e415                          ldi     Rtmp1, 'E'
00010d d0c6                          rcall   LCD_PutChar
00010e e512                          ldi     Rtmp1, 'R'
00010f d0c4                          rcall   LCD_PutChar
                                     
000110 e012                          ldi     Rtmp1, 2
000111 9310 0102                     sts     STATE, Rtmp1
                                     
000113 d127                          rcall   WaitKeyRelease
000114 940c 0010                     jmp     MainLoop
                                 
                                 ;------------ DIV : OP1 / OP2 (2 decimal digits) ------------- 
                                 ; Result format: Q.D1D2 
                                 ; Uses: Rtmp0..Rtmp3, Rval, RremLo/Hi, Rdec1, Rdec2, Rzero 
                                 ;------------------------------------------------------ 
                                 Do_Div: 
                                     ; Load operands 
000116 9110 0100                     lds Rtmp1, OP1 ; A = dividend 
000118 9120 0101                     lds Rtmp2, OP2 ; B = divisor 
                                 
                                     ; Divide by zero ? 
00011a 3020                          cpi Rtmp2, 0 
00011b f411                          brne Div_NotZero
00011c 940c 015e                     jmp Div_By_Zero
                                 
                                 Div_NotZero: 
                                 
                                     ; ***** SAVE DIVISOR BEFORE IT GETS DESTROYED ***** 
00011e 2ec2                          mov r12, Rtmp2 ; Save divisor in r12 (unused register) 
                                 
                                     ;-------------------------------------- 
                                     ; 1) Integer part Q and remainder R 
                                     ;-------------------------------------- 
00011f 2744                          clr Rval ; Q = 0 
000120 2f71                          mov RremLo, Rtmp1 ; R = A 
000121 2788                          clr RremHi 
                                 
                                 Div_IntLoop: 
000122 1772                          cp RremLo, Rtmp2 
000123 f018                          brlo Div_IntDone 
000124 1b72                          sub RremLo, Rtmp2 
000125 9543                          inc Rval 
000126 cffb                          rjmp Div_IntLoop 
                                 
                                 Div_IntDone: 
                                     ; Now: Q in Rval, remainder R in RremLo (RremHi = 0) 
                                 
                                     ;-------------------------------------- 
                                     ; Move cursor to 2nd line and print Q 
                                     ;-------------------------------------- 
000127 ec00                          ldi Rtmp0, 0xC0 
000128 d0a5                          rcall LCD_Command 
                                 
                                     ; Print integer part Q (Rval) - this destroys Rtmp0-Rtmp3 
000129 d062                          rcall Print_0_199 
                                 
                                     ; Print decimal point '.' 
00012a e21e                          ldi Rtmp1, '.' 
00012b d0a8                          rcall LCD_PutChar 
                                 
                                     ; ***** RESTORE DIVISOR ***** 
00012c 2d2c                          mov Rtmp2, r12 ; Restore divisor from r12 
                                 
                                     ;-------------------------------------- 
                                     ; 2) First decimal digit D1 
                                     ; D1 = floor( (R * 10) / B ) 
                                     ;-------------------------------------- 
00012d 2f37                          mov Rtmp3, RremLo ; save R (8-bit) 
00012e 2777                          clr RremLo 
00012f 2788                          clr RremHi 
000130 e00a                          ldi Rtmp0, 10 ; loop counter for *10 
                                 
                                 D1_Mul10: 
000131 0f73                          add RremLo, Rtmp3 
000132 1d8f                          adc RremHi, Rzero 
000133 950a                          dec Rtmp0 
000134 f7e1                          brne D1_Mul10 
                                 
                                     ; Divide 16-bit Rrem by B ? D1 in Rdec1 
000135 24aa                          clr Rdec1 ; D1 = 0 
                                 
                                 D1_DivLoop: 
000136 2388                          tst RremHi 
000137 f411                          brne D1_DoSub 
000138 1772                          cp RremLo, Rtmp2 
000139 f020                          brlo D1_Done 
                                 
                                 D1_DoSub: 
00013a 1b72                          sub RremLo, Rtmp2 
00013b 098f                          sbc RremHi, Rzero 
00013c 94a3                          inc Rdec1 
00013d cff8                          rjmp D1_DivLoop 
                                 
                                 D1_Done: 
                                     ; Rdec1 = D1, remainder1 in RremHi:RremLo 
                                 
                                     ;-------------------------------------- 
                                     ; 3) Second decimal digit D2 
                                     ; D2 = floor( (R1 * 10) / B ) 
                                     ;-------------------------------------- 
00013e 2f37                          mov Rtmp3, RremLo ; R1 low 
00013f 2f18                          mov Rtmp1, RremHi ; R1 high 
000140 2777                          clr RremLo 
000141 2788                          clr RremHi 
000142 e00a                          ldi Rtmp0, 10 ; loop counter for *10 
                                 
                                 D2_Mul10: 
000143 0f73                          add RremLo, Rtmp3 
000144 1f81                          adc RremHi, Rtmp1 
000145 950a                          dec Rtmp0 
000146 f7e1                          brne D2_Mul10 
                                 
000147 24bb                          clr Rdec2 ; D2 = 0 
                                 
                                 D2_DivLoop: 
000148 2388                          tst RremHi 
000149 f411                          brne D2_DoSub 
00014a 1772                          cp RremLo, Rtmp2 
00014b f020                          brlo D2_Done 
                                 
                                 D2_DoSub: 
00014c 1b72                          sub RremLo, Rtmp2 
00014d 098f                          sbc RremHi, Rzero 
00014e 94b3                          inc Rdec2 
00014f cff8                          rjmp D2_DivLoop 
                                 
                                 D2_Done: 
                                     ; Rdec1 = first decimal digit, Rdec2 = second 
                                 
                                     ;-------------------------------------- 
                                     ; 4) Print D1 and D2 
                                     ;-------------------------------------- 
000150 2d1a                          mov Rtmp1, Rdec1 
000151 e300                          ldi Rtmp0, '0' 
